<!-- QUICK LOG DRAWER -->
<div class="quick-log-overlay" id="quickLogOverlay" onclick="if(event.target===this)closeQuickLog();">
  <div class="quick-log-panel">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">
      <div>
        <div style="font-weight:800;font-size:1.05rem;color:var(--gray-800);">Quick Daily Log</div>
        <div class="text-xs text-muted">Thursday, Mar 27</div>
      </div>
      <button onclick="closeQuickLog()" style="font-size:1.3rem;color:var(--gray-400);padding:4px;">&times;</button>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;">
      <div>
        <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Calories</label>
        <input type="number" placeholder="1650" style="font-size:.95rem;">
      </div>
      <div>
        <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Protein (g)</label>
        <input type="number" placeholder="120" style="font-size:.95rem;">
      </div>
      <div>
        <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Steps</label>
        <input type="number" placeholder="10000" style="font-size:.95rem;">
      </div>
      <div>
        <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Sleep (hrs)</label>
        <input type="number" step="0.1" placeholder="7.5" style="font-size:.95rem;">
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:18px;">
      <div>
        <label class="text-xs text-muted" style="display:block;margin-bottom:6px;">Energy</label>
        <div class="rating-group">
          <button class="rating-btn" onclick="setRating(this)" style="width:36px;height:36px;font-size:.82rem;">1</button>
          <button class="rating-btn" onclick="setRating(this)" style="width:36px;height:36px;font-size:.82rem;">2</button>
          <button class="rating-btn selected" onclick="setRating(this)" style="width:36px;height:36px;font-size:.82rem;">3</button>
          <button class="rating-btn" onclick="setRating(this)" style="width:36px;height:36px;font-size:.82rem;">4</button>
          <button class="rating-btn" onclick="setRating(this)" style="width:36px;height:36px;font-size:.82rem;">5</button>
        </div>
      </div>
      <div>
        <label class="text-xs text-muted" style="display:block;margin-bottom:6px;">Hunger</label>
        <div class="rating-group">
          <button class="rating-btn" onclick="setRating(this)" style="width:36px;height:36px;font-size:.82rem;">1</button>
          <button class="rating-btn" onclick="setRating(this)" style="width:36px;height:36px;font-size:.82rem;">2</button>
          <button class="rating-btn selected" onclick="setRating(this)" style="width:36px;height:36px;font-size:.82rem;">3</button>
          <button class="rating-btn" onclick="setRating(this)" style="width:36px;height:36px;font-size:.82rem;">4</button>
          <button class="rating-btn" onclick="setRating(this)" style="width:36px;height:36px;font-size:.82rem;">5</button>
        </div>
      </div>
    </div>

    <button class="btn btn-primary w-full" onclick="showToast('Daily log saved!');closeQuickLog();" style="padding:12px;">Save Log</button>
  </div>
</div>

