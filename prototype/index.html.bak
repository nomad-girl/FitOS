    <!-- ============================================================
         3. PHASES (now inside Plan tab — this wrapper is hidden/deprecated)
         ============================================================ -->
    <div class="main-content" id="phasesWrapper" style="display:none !important;">
      <div class="screen active" id="screen-phases">

        <div class="page-header">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
            <div>
              <h1>Phases</h1>
              <p>Manage your training phases and periodization</p>
            </div>
            <button class="btn btn-primary" onclick="showNewPhaseWizard()">+ New Phase</button>
          </div>
        </div>

        <!-- Active Phase (Prominent) -->
        <div class="phase-card-active fade-in">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
            <div>
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
