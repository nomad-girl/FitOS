                    <tr><td><span class="set-number">1</span></td><td><input class="set-input" type="text" placeholder="--"></td><td><div class="rep-range-cell"><input class="set-input set-input-sm" value="12"><span>-</span><input class="set-input set-input-sm" value="15"></div></td><td><select class="rpe-select"><option>8</option><option>8.5</option><option selected>9</option><option>9.5</option></select></td><td><button class="set-delete">&times;</button></td></tr>
                    <tr><td><span class="set-number">2</span></td><td><input class="set-input" type="text" placeholder="--"></td><td><div class="rep-range-cell"><input class="set-input set-input-sm" value="12"><span>-</span><input class="set-input set-input-sm" value="15"></div></td><td><select class="rpe-select"><option>8</option><option>8.5</option><option selected>9</option><option>9.5</option></select></td><td><button class="set-delete">&times;</button></td></tr>
                    <tr><td><span class="set-number">3</span></td><td><input class="set-input" type="text" placeholder="--"></td><td><div class="rep-range-cell"><input class="set-input set-input-sm" value="12"><span>-</span><input class="set-input set-input-sm" value="15"></div></td><td><select class="rpe-select"><option>8</option><option>8.5</option><option selected>9</option><option>9.5</option></select></td><td><button class="set-delete">&times;</button></td></tr>
                  </tbody>
                </table>
                <button class="add-set-btn">+ Add set</button>
              </div>
            </div>

            <!-- Exercise 7: Plank -->
            <div class="exercise-block">
              <div class="exercise-block-header">
                <div class="exercise-block-icon">&#x1F9D8;</div>
                <div class="exercise-block-title">
                  <div class="exercise-block-name">Plank</div>
                  <div class="exercise-block-muscle">Core &middot; Isometric</div>
                </div>
                <span style="cursor:grab;color:var(--gray-300);font-size:.9rem;margin-right:2px;" title="Drag to reorder">&#x2630;</span><button class="exercise-block-menu">&#x22EE;</button>
              </div>
              <div class="exercise-block-body">
                <textarea class="exercise-block-note" placeholder="Add pinned note"></textarea>
                <div class="exercise-block-rest">
                  <span>Rest Timer:</span>
                  <select><option selected>01:00</option><option>01:30</option></select>
                </div>
                <table class="set-table">
                  <thead><tr><th>SET</th><th>DURATION</th><th>TARGET RPE</th><th></th></tr></thead>
                  <tbody>
                    <tr><td><span class="set-number">1</span></td><td><input class="set-input" value="45s" style="max-width:80px;"></td><td><select class="rpe-select"><option>7</option><option selected>8</option><option>8.5</option><option>9</option></select></td><td><button class="set-delete">&times;</button></td></tr>
                    <tr><td><span class="set-number">2</span></td><td><input class="set-input" value="45s" style="max-width:80px;"></td><td><select class="rpe-select"><option>7</option><option selected>8</option><option>8.5</option><option>9</option></select></td><td><button class="set-delete">&times;</button></td></tr>
                    <tr><td><span class="set-number">3</span></td><td><input class="set-input" value="45s" style="max-width:80px;"></td><td><select class="rpe-select"><option>7</option><option selected>8</option><option>8.5</option><option>9</option></select></td><td><button class="set-delete">&times;</button></td></tr>
                  </tbody>
                </table>
                <button class="add-set-btn">+ Add set</button>
              </div>
            </div>
          </div>

          <button class="add-btn-dashed mt-2" onclick="showExerciseLibraryInPanel()">+ Add Exercise</button>
          <div style="height:40px;"></div>
        </div>
      </div>
    </div>

    <!-- PLAN RIGHT PANEL -->
    <div class="right-panel" id="planPanel">
      <!-- SUMMARY VIEW (default) -->
      <div id="planPanelSummary">
        <div class="panel-title">Summary</div>

        <div class="grid-2" style="margin-bottom:20px;">
          <div class="card card-sm" style="text-align:center;margin-bottom:0;">
            <div class="text-xs text-muted">Exercises</div>
            <div style="font-size:1.3rem;font-weight:800;">21</div>
          </div>
          <div class="card card-sm" style="text-align:center;margin-bottom:0;">
            <div class="text-xs text-muted">Total Sets</div>
            <div style="font-size:1.3rem;font-weight:800;">74</div>
          </div>
        </div>

        <!-- Stats tabs -->
        <div class="tab-bar" style="margin-bottom:18px;">
          <div class="tab-btn active" onclick="switchStatsTab(this,'muscles')">Muscles</div>
          <div class="tab-btn" onclick="switchStatsTab(this,'patterns')">Patterns</div>
        </div>

        <!-- Muscle tab -->
        <div id="statsMuscles">
          <table class="muscle-table">
            <tr><td><span class="dot dot-red"></span></td><td class="m-name">Glutes</td><td class="m-count" style="color:var(--danger);font-weight:700;">8 / 14</td></tr>
            <tr><td><span class="dot dot-green"></span></td><td class="m-name">Back</td><td class="m-count">15 / 14</td></tr>
            <tr><td><span class="dot dot-green"></span></td><td class="m-name">Quads</td><td class="m-count">12 / 12</td></tr>
            <tr><td><span class="dot dot-green"></span></td><td class="m-name">Hamstrings</td><td class="m-count">10 / 10</td></tr>
            <tr><td><span class="dot dot-green"></span></td><td class="m-name">Chest</td><td class="m-count">9 / 8</td></tr>
            <tr><td><span class="dot dot-yellow"></span></td><td class="m-name">Shoulders</td><td class="m-count" style="color:var(--warning);">6 / 8</td></tr>
            <tr><td><span class="dot dot-green"></span></td><td class="m-name">Biceps</td><td class="m-count">6 / 6</td></tr>
            <tr><td><span class="dot dot-green"></span></td><td class="m-name">Triceps</td><td class="m-count">6 / 6</td></tr>
            <tr><td><span class="dot dot-yellow"></span></td><td class="m-name">Core</td><td class="m-count" style="color:var(--warning);">9 / 6</td></tr>
            <tr><td><span class="dot dot-yellow"></span></td><td class="m-name">Calves</td><td class="m-count" style="color:var(--warning);">2 / 4</td></tr>
          </table>

          <!-- sessionChips moved to exercise library panel -->

          <div class="alert-card alert-warning">&#x26A0;&#xFE0F; Glutes: 6 sets below target</div>
          <div class="alert-card alert-info" style="margin-top:8px;">&#x2696;&#xFE0F; Push:Pull ratio balanced</div>
        </div>

        <!-- Patterns tab -->
        <div id="statsPatterns" style="display:none;">
          <div style="padding:4px 0;">
            <div class="bar-row"><span class="bar-label">Squat</span><div class="bar-track"><div class="bar-fill" style="width:40%;"><span class="bar-val">8</span></div></div></div>
            <div class="bar-row"><span class="bar-label">Hinge</span><div class="bar-track"><div class="bar-fill" style="width:50%;"><span class="bar-val">10</span></div></div></div>
            <div class="bar-row"><span class="bar-label">H. Push</span><div class="bar-track"><div class="bar-fill" style="width:30%;"><span class="bar-val">6</span></div></div></div>
            <div class="bar-row"><span class="bar-label">H. Pull</span><div class="bar-track"><div class="bar-fill" style="width:30%;"><span class="bar-val">6</span></div></div></div>
            <div class="bar-row"><span class="bar-label">V. Push</span><div class="bar-track"><div class="bar-fill" style="width:15%;"><span class="bar-val">3</span></div></div></div>
            <div class="bar-row"><span class="bar-label">V. Pull</span><div class="bar-track"><div class="bar-fill" style="width:15%;"><span class="bar-val">3</span></div></div></div>
            <div class="bar-row"><span class="bar-label">Isolation</span><div class="bar-track"><div class="bar-fill" style="width:100%;"><span class="bar-val">20</span></div></div></div>
          </div>
        </div>
      </div>

      <!-- PHASE INFO PANEL (shown when Phase sub-tab is active) -->
      <div id="planPanelPhaseInfo" style="display:none;">
        <div class="panel-title">Phase Health</div>
        <div class="border-card" style="margin-bottom:18px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <span style="font-weight:600;font-size:.9rem;">Status</span>
            <span class="badge badge-green">On Track</span>
          </div>
          <div style="display:flex;flex-direction:column;gap:10px;font-size:.84rem;">
            <div style="display:flex;justify-content:space-between;"><span class="text-muted">Performance &#x2193;</span><span style="font-weight:600;">0/3 wk</span></div>
            <div style="display:flex;justify-content:space-between;"><span class="text-muted">Energy &#x2264;2</span><span style="font-weight:600;">0/2 wk</span></div>
            <div style="display:flex;justify-content:space-between;"><span class="text-muted">Hunger &#x2265;4</span><span style="font-weight:600;color:var(--warning);">1/3 wk</span></div>
            <div style="display:flex;justify-content:space-between;"><span class="text-muted">Weight stall</span><span style="font-weight:600;">0/2 wk</span></div>
          </div>
        </div>

        <div class="panel-title">Phase Summary</div>
        <div class="card card-sm" style="background:var(--gray-50);margin-bottom:0;">
          <div style="font-size:.84rem;display:flex;flex-direction:column;gap:8px;">
            <div style="display:flex;justify-content:space-between;"><span class="text-muted">Total phases</span><span style="font-weight:700;">3</span></div>
            <div style="display:flex;justify-content:space-between;"><span class="text-muted">Training since</span><span style="font-weight:700;">Oct 2024</span></div>
            <div style="display:flex;justify-content:space-between;"><span class="text-muted">Avg adherence</span><span style="font-weight:700;">92%</span></div>
            <div style="display:flex;justify-content:space-between;"><span class="text-muted">Current streak</span><span style="font-weight:700;">22 weeks</span></div>
          </div>
        </div>
      </div>

      <!-- EXERCISE LIBRARY (shown automatically in session editor, like Hevy Coach) -->
      <div id="planPanelExercises" style="display:none;">
        <!-- Session muscle contribution -->
        <div id="sessionChips" style="margin-bottom:16px;padding:12px 14px;background:var(--primary-light);border-radius:var(--radius-sm);">
          <div class="text-xs font-bold" style="color:var(--primary-dark);margin-bottom:8px;">This Session Adds</div>
          <div style="display:flex;flex-wrap:wrap;gap:5px;">
            <span class="badge badge-blue" style="font-size:.7rem;">Glutes +7</span>
            <span class="badge badge-blue" style="font-size:.7rem;">Quads +4</span>
            <span class="badge badge-blue" style="font-size:.7rem;">Back +3</span>
            <span class="badge badge-blue" style="font-size:.7rem;">Hams +4</span>
            <span class="badge badge-blue" style="font-size:.7rem;">Chest +3</span>
            <span class="badge badge-blue" style="font-size:.7rem;">Core +3</span>
          </div>
        </div>

        <!-- + Custom Exercise link -->
        <div style="text-align:center;margin-bottom:16px;">
          <button onclick="showToast('Custom Exercise coming soon')" style="color:var(--primary);font-weight:600;font-size:.9rem;background:none;border:none;cursor:pointer;">+ Custom Exercise</button>
        </div>

        <!-- Filters (Hevy style) -->
        <div style="display:flex;gap:8px;margin-bottom:12px;">
          <select id="exLibEquip" style="flex:1;padding:8px 10px;font-size:.84rem;" onchange="filterExLib()">
            <option value="">Equipment</option>
            <option>Barbell</option>
            <option>Dumbbell</option>
            <option>Cable</option>
            <option>Machine</option>
            <option>Bodyweight</option>
            <option>Band</option>
          </select>
          <select id="exLibMuscle" style="flex:1;padding:8px 10px;font-size:.84rem;" onchange="filterExLib()">
            <option value="">Muscles</option>
            <option>Glutes</option>
            <option>Back</option>
            <option>Quads</option>
            <option>Hamstrings</option>
            <option>Chest</option>
            <option>Shoulders</option>
            <option>Biceps</option>
            <option>Triceps</option>
            <option>Core</option>
            <option>Calves</option>
          </select>
        </div>

        <!-- Search -->
        <div style="position:relative;margin-bottom:16px;">
          <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--gray-400);font-size:.9rem;">&#x1F50D;</span>
          <input type="text" id="exLibSearch" placeholder="Search exercises" style="padding-left:36px;font-size:.87rem;" oninput="filterExLib()">
        </div>

        <!-- Exercise list (scrollable) -->
        <div style="font-size:.77rem;font-weight:600;color:var(--gray-400);margin-bottom:10px;">All Exercises</div>
        <div id="exLibList" style="display:flex;flex-direction:column;gap:2px;max-height:calc(100vh - 320px);overflow-y:auto;">
          <div class="ex-lib-item" data-name="21s Bicep Curl" data-muscle="Biceps" data-equip="Barbell" onclick="showToast('21s Bicep Curl added!')">
            <span class="ex-lib-plus">+</span>
            <div class="ex-lib-icon">&#x1F4AA;</div>
            <div class="ex-lib-info"><div class="ex-lib-name">21s Bicep Curl</div><div class="ex-lib-meta">Biceps</div></div>
          </div>
          <div class="ex-lib-item" data-name="Ab Scissors" data-muscle="Core" data-equip="Bodyweight" onclick="showToast('Ab Scissors added!')">
