<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FitOS — Training Planner</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ============================================================
   DESIGN TOKENS
   ============================================================ */
:root {
  --primary: #0EA5E9;
  --primary-light: #F0F9FF;
  --primary-dark: #0369A1;
  --accent: #06B6D4;
  --success: #10B981;
  --success-light: #D1FAE5;
  --warning: #F59E0B;
  --warning-light: #FEF3C7;
  --danger: #EF4444;
  --danger-light: #FEE2E2;
  --bg: #FAFBFD;
  --card: #FFFFFF;
  --gray-50: #F9FAFB;
  --gray-100: #F3F4F6;
  --gray-200: #E5E7EB;
  --gray-300: #D1D5DB;
  --gray-400: #9CA3AF;
  --gray-500: #6B7280;
  --gray-600: #4B5563;
  --gray-700: #374151;
  --gray-800: #1F2937;
  --gray-900: #111827;
  --radius: 16px;
  --radius-sm: 10px;
  --radius-xs: 6px;
  --shadow: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
  --shadow-md: 0 4px 12px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.04);
  --shadow-lg: 0 10px 30px rgba(0,0,0,.08), 0 2px 6px rgba(0,0,0,.04);
  --sidebar-w: 240px;
  --panel-w: 340px;
  --transition: .2s ease;
}

/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 15.5px; -webkit-font-smoothing: antialiased; }
body {
  font-family: 'Inter', -apple-system, sans-serif;
  background: var(--bg);
  color: var(--gray-800);
  line-height: 1.6;
  min-height: 100vh;
}
a { color: var(--primary); text-decoration: none; }
button {
  font-family: inherit;
  cursor: pointer;
  border: none;
  background: none;
  font-size: inherit;
}
input, textarea, select {
  font-family: inherit;
  font-size: inherit;
  border: 1.5px solid var(--gray-200);
  border-radius: var(--radius-sm);
  padding: 10px 14px;
  background: var(--card);
  color: var(--gray-800);
  outline: none;
  transition: border-color var(--transition);
  width: 100%;
}
input:focus, textarea:focus, select:focus { border-color: var(--primary); }
textarea { resize: vertical; min-height: 80px; }

/* ============================================================
   ANIMATIONS
   ============================================================ */
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: none; } }
@keyframes fadeScale { from { opacity: 0; transform: scale(.96); } to { opacity: 1; transform: scale(1); } }
@keyframes spin { to { transform: rotate(360deg); } }
.fade-in { animation: fadeIn .35s ease both; }
.slide-up { animation: slideUp .4s ease both; }

/* ============================================================
   LAYOUT SHELL
   ============================================================ */
.app-shell { display: flex; min-height: 100vh; }

/* SIDEBAR */
.sidebar {
  width: var(--sidebar-w);
  background: var(--card);
  border-right: 1px solid var(--gray-100);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0; left: 0; bottom: 0;
  z-index: 100;
  transition: transform .3s ease;
}
.sidebar-logo {
  padding: 28px 24px 20px;
  font-weight: 800;
  font-size: 1.35rem;
  color: var(--primary-dark);
  letter-spacing: -.02em;
}
.sidebar-logo span { color: var(--accent); }
.sidebar-divider { height: 1px; background: var(--gray-100); margin: 0 16px; }
.sidebar-nav { flex: 1; padding: 12px 10px; display: flex; flex-direction: column; gap: 2px; }
.nav-item {
  display: flex; align-items: center; gap: 12px;
  padding: 11px 16px;
  border-radius: var(--radius-sm);
  color: var(--gray-500);
  font-weight: 500;
  font-size: .92rem;
  transition: all var(--transition);
  cursor: pointer;
}
.nav-item:hover { background: var(--gray-50); color: var(--gray-700); }
.nav-item.active { background: var(--primary-light); color: var(--primary-dark); font-weight: 600; }
.nav-item .nav-icon { font-size: 1.1rem; width: 22px; text-align: center; }
.sidebar-user {
  padding: 16px;
  border-top: 1px solid var(--gray-100);
  display: flex; align-items: center; gap: 12px;
  cursor: pointer;
  transition: background var(--transition);
}
.sidebar-user:hover { background: var(--gray-50); }
.user-avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: .85rem;
}
.user-info { flex: 1; }
.user-name { font-weight: 600; font-size: .88rem; color: var(--gray-800); }
.user-role { font-size: .75rem; color: var(--gray-400); }

/* MAIN AREA */
.main-area {
  flex: 1;
  margin-left: var(--sidebar-w);
  display: flex;
  min-height: 100vh;
}
.main-content {
  flex: 1;
  padding: 36px 44px;
  max-width: 100%;
  overflow-x: hidden;
}

/* RIGHT PANEL */
.right-panel {
  width: var(--panel-w);
  min-width: var(--panel-w);
  background: var(--card);
  border-left: 1px solid var(--gray-100);
  padding: 32px 24px;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
  display: none;
}
.right-panel.visible { display: block; }

/* BOTTOM TABS (mobile) */
.bottom-tabs {
  display: none;
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--card);
  border-top: 1px solid var(--gray-100);
  z-index: 200;
  padding: 6px 0 env(safe-area-inset-bottom, 6px);
}
.bottom-tabs-inner {
  display: flex;
  justify-content: space-around;
}
.btab {
  display: flex; flex-direction: column; align-items: center; gap: 3px;
  padding: 6px 0;
  font-size: .65rem;
  color: var(--gray-400);
  font-weight: 500;
  cursor: pointer;
  transition: color var(--transition);
  flex: 1;
}
.btab .btab-icon { font-size: 1.25rem; }
.btab.active { color: var(--primary); }

/* ============================================================
   MOBILE STATS DRAWER
   ============================================================ */
.stats-drawer-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,.35);
  z-index: 300;
}
.stats-drawer-overlay.open { display: block; }
.stats-drawer {
  position: fixed;
  right: -100%; top: 0; bottom: 0;
  width: 85vw; max-width: 380px;
  background: var(--card);
  z-index: 301;
  padding: 24px 20px;
  overflow-y: auto;
  transition: right .3s ease;
}
.stats-drawer-overlay.open .stats-drawer { right: 0; }

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 768px) {
  .sidebar { transform: translateX(-100%); }
  .main-area { margin-left: 0; }
  .bottom-tabs { display: block; }
  .main-content { padding: 20px 16px 90px !important; max-width: 100% !important; }
  .right-panel { display: none !important; }
  .mobile-stats-btn { display: inline-flex !important; }
}

/* ============================================================
   COMMON COMPONENTS
   ============================================================ */
.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 24px 26px;
  box-shadow: var(--shadow);
  margin-bottom: 18px;
}
.card-sm { padding: 18px 22px; }

.section-title {
  font-size: 1.08rem;
  font-weight: 700;
  color: var(--gray-800);
  margin-bottom: 16px;
  display: flex; align-items: center; gap: 8px;
}
.section-subtitle {
  font-size: .84rem;
  color: var(--gray-500);
  font-weight: 400;
}

.badge {
  display: inline-flex;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: .73rem;
  font-weight: 600;
  letter-spacing: .01em;
}
.badge-blue { background: var(--primary-light); color: var(--primary-dark); }
.badge-green { background: var(--success-light); color: #065F46; }
.badge-yellow { background: var(--warning-light); color: #92400E; }
.badge-red { background: var(--danger-light); color: #991B1B; }
.badge-gray { background: var(--gray-100); color: var(--gray-600); }

.pill {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 5px 12px;
  border-radius: 20px;
  font-size: .78rem;
  font-weight: 500;
  background: rgba(255,255,255,.2);
  color: inherit;
}

.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  padding: 10px 22px;
  border-radius: var(--radius-sm);
  font-weight: 600;
  font-size: .9rem;
  transition: all var(--transition);
}
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--accent));
  color: #fff;
  box-shadow: 0 2px 8px rgba(14,165,233,.25);
}
.btn-primary:hover { box-shadow: 0 4px 16px rgba(14,165,233,.35); transform: translateY(-1px); }
.btn-outline {
  border: 1.5px solid var(--gray-200);
  color: var(--gray-600);
  background: var(--card);
}
.btn-outline:hover { border-color: var(--primary); color: var(--primary); }
.btn-ghost { color: var(--gray-500); }
.btn-ghost:hover { color: var(--primary); background: var(--primary-light); }
.btn-sm { padding: 7px 14px; font-size: .82rem; }
.btn-danger-outline { border: 1.5px solid var(--danger); color: var(--danger); background: transparent; }
.btn-danger-outline:hover { background: var(--danger-light); }

.page-header { margin-bottom: 28px; }
.page-header h1 {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--gray-900);
  letter-spacing: -.02em;
}
.page-header p {
  color: var(--gray-500);
  font-size: .9rem;
  margin-top: 4px;
}

.gradient-card {
  background: linear-gradient(135deg, #1d9be2, #1aafcf);
  color: #fff;
  border-radius: var(--radius);
  padding: 26px 30px;
  margin-bottom: 18px;
}
.gradient-card-dark {
  background: linear-gradient(135deg, #0f4d6e, #175563);
  color: #fff;
  border-radius: var(--radius);
  padding: 26px 30px;
  margin-bottom: 18px;
}

.rating-group { display: flex; gap: 6px; }
.rating-btn {
  width: 44px; height: 44px;
  border-radius: var(--radius-sm);
  border: 1.5px solid var(--gray-200);
  font-weight: 600;
  font-size: .92rem;
  color: var(--gray-500);
  display: flex; align-items: center; justify-content: center;
  transition: all var(--transition);
}
.rating-btn:hover { border-color: var(--primary); color: var(--primary); }
.rating-btn.selected {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.chip-group { display: flex; flex-wrap: wrap; gap: 8px; }
.chip {
  padding: 7px 16px;
  border-radius: 20px;
  border: 1.5px solid var(--gray-200);
  font-size: .84rem;
  font-weight: 500;
  color: var(--gray-600);
  cursor: pointer;
  transition: all var(--transition);
}
.chip:hover { border-color: var(--primary); color: var(--primary); }
.chip.selected {
  background: var(--primary-light);
  border-color: var(--primary);
  color: var(--primary-dark);
}

.progress-bar {
  height: 6px;
  background: var(--gray-100);
  border-radius: 8px;
  overflow: hidden;
}
.progress-bar .fill {
  height: 100%;
  border-radius: 8px;
  transition: width .6s ease;
}
.fill-blue { background: linear-gradient(90deg, var(--primary), var(--accent)); }
.fill-green { background: var(--success); }
.fill-yellow { background: var(--warning); }
.fill-red { background: var(--danger); }

.score-ring {
  width: 100px; height: 100px;
  position: relative;
  display: inline-flex; align-items: center; justify-content: center;
}
.score-ring svg { position: absolute; inset: 0; transform: rotate(-90deg); }
.score-ring .score-val {
  font-size: 1.6rem;
  font-weight: 800;
  z-index: 1;
}

.toast {
  position: fixed;
  bottom: 100px;
  left: 50%; transform: translateX(-50%) translateY(20px);
  background: var(--gray-800);
  color: #fff;
  padding: 12px 24px;
  border-radius: var(--radius-sm);
  font-size: .9rem;
  font-weight: 500;
  box-shadow: var(--shadow-lg);
  z-index: 1000;
  opacity: 0;
  transition: all .3s ease;
  pointer-events: none;
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

.mobile-stats-btn {
  display: none !important;
  align-items: center; gap: 6px;
  padding: 8px 16px;
  background: var(--primary-light);
  color: var(--primary-dark);
  border-radius: var(--radius-sm);
  font-weight: 600;
  font-size: .84rem;
  cursor: pointer;
  border: none;
}

/* FAB - Quick Daily Log */
.fab {
  position: fixed;
  bottom: 28px;
  right: 28px;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  color: #fff;
  font-size: 1.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(14,165,233,.35), 0 2px 6px rgba(0,0,0,.1);
  cursor: pointer;
  border: none;
  z-index: 250;
  transition: all .25s ease;
}
.fab:hover {
  transform: scale(1.08);
  box-shadow: 0 6px 24px rgba(14,165,233,.45), 0 2px 8px rgba(0,0,0,.12);
}
.fab:active { transform: scale(.95); }
.fab-label {
  position: fixed;
  bottom: 36px;
  right: 92px;
  background: var(--gray-800);
  color: #fff;
  padding: 6px 14px;
  border-radius: var(--radius-xs);
  font-size: .78rem;
  font-weight: 600;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity .2s ease;
  z-index: 250;
}
.fab:hover + .fab-label { opacity: 1; }

/* Quick Log Drawer */
.quick-log-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,.35);
  z-index: 400;
  justify-content: flex-end;
  align-items: flex-end;
}
.quick-log-overlay.open { display: flex; }
.quick-log-panel {
  background: var(--card);
  border-radius: var(--radius) var(--radius) 0 0;
  width: 420px;
  max-width: 100vw;
  padding: 28px;
  box-shadow: 0 -8px 30px rgba(0,0,0,.12);
  animation: slideUp .3s ease;
  position: fixed;
  bottom: 0;
  right: 28px;
}
@media (max-width: 768px) {
  .fab { bottom: 80px; right: 16px; }
  .fab-label { display: none; }
  .quick-log-panel { right: 0; width: 100%; }
}

.tab-bar { display: flex; gap: 4px; margin-bottom: 22px; background: var(--gray-100); border-radius: var(--radius-sm); padding: 3px; }
.tab-btn {
  padding: 8px 18px;
  border-radius: 8px;
  font-weight: 600;
  font-size: .87rem;
  color: var(--gray-500);
  transition: all var(--transition);
  cursor: pointer;
}
.tab-btn.active { background: var(--card); color: var(--gray-800); box-shadow: var(--shadow); }

.dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
.dot-green { background: var(--success); }
.dot-yellow { background: var(--warning); }
.dot-red { background: var(--danger); }

.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
@media (max-width: 600px) {
  .grid-2, .grid-3 { grid-template-columns: 1fr; }
}

.screen { display: none; }
.screen.active { display: block; animation: fadeIn .3s ease both; }

.profile-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,.4);
  z-index: 500;
  justify-content: center;
  align-items: center;
}
.profile-overlay.open { display: flex; }
.profile-panel {
  background: var(--card);
  border-radius: var(--radius);
  width: 480px;
  max-width: 90vw;
  max-height: 85vh;
  overflow-y: auto;
  padding: 32px;
  box-shadow: var(--shadow-lg);
  animation: fadeScale .25s ease;
}

.exercise-modal-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,.4);
  z-index: 500;
  justify-content: center;
  align-items: center;
}
.exercise-modal-overlay.open { display: flex; }
.exercise-modal {
  background: var(--card);
  border-radius: var(--radius);
  width: 560px;
  max-width: 95vw;
  max-height: 85vh;
  overflow-y: auto;
  padding: 28px;
  box-shadow: var(--shadow-lg);
  animation: fadeScale .25s ease;
}

.add-btn-dashed {
  width: 100%;
  padding: 14px;
  border: 2px dashed var(--gray-200);
  border-radius: var(--radius-sm);
  color: var(--gray-400);
  font-weight: 600;
  font-size: .9rem;
  text-align: center;
  cursor: pointer;
  transition: all var(--transition);
}
.add-btn-dashed:hover { border-color: var(--primary); color: var(--primary); }

.mini-table { width: 100%; font-size: .8rem; border-collapse: collapse; }
.mini-table th, .mini-table td { padding: 7px 8px; text-align: center; }
.mini-table th { color: var(--gray-400); font-weight: 600; font-size: .72rem; text-transform: uppercase; }
.mini-table td { color: var(--gray-600); }
.mini-table tr { border-bottom: 1px solid var(--gray-50); }

.muscle-table { width: 100%; font-size: .84rem; }
.muscle-table td { padding: 8px 4px; vertical-align: middle; }
.muscle-table .m-name { font-weight: 500; color: var(--gray-700); }
.muscle-table .m-count { color: var(--gray-500); text-align: right; white-space: nowrap; }

.bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; font-size: .84rem; }
.bar-label { width: 74px; text-align: right; color: var(--gray-500); font-weight: 500; flex-shrink: 0; }
.bar-track { flex: 1; height: 20px; background: var(--gray-100); border-radius: 6px; overflow: hidden; position: relative; }
.bar-fill { height: 100%; border-radius: 6px; background: linear-gradient(90deg, var(--primary), var(--accent)); display: flex; align-items: center; justify-content: flex-end; padding-right: 6px; }
.bar-val { font-size: .72rem; font-weight: 700; color: #fff; }

/* Exercise Editor Block (Hevy Coach style) */
.exercise-block {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 14px;
  overflow: hidden;
}
.exercise-block-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 18px 20px 12px;
}
.exercise-block-icon {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  background: var(--gray-50);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  flex-shrink: 0;
}
.exercise-block-title { flex: 1; }
.exercise-block-name {
  font-weight: 700;
  font-size: .97rem;
  color: var(--gray-800);
}
.exercise-block-muscle {
  font-size: .77rem;
  color: var(--gray-400);
  margin-top: 1px;
}
.exercise-block-menu {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: none;
  background: transparent;
  cursor: pointer;
  color: var(--gray-400);
  font-size: 1.2rem;
  display: flex;
  align-items: center;
  justify-content: center;
}
.exercise-block-menu:hover { background: var(--gray-100); color: var(--gray-600); }
.exercise-block-body { padding: 0 20px 16px; }
.exercise-block-note {
  width: 100%;
  padding: 8px 12px;
  border: 1.5px solid var(--gray-200);
  border-radius: var(--radius-xs);
  font-family: inherit;
  font-size: .82rem;
  color: var(--gray-600);
  margin-bottom: 10px;
  resize: none;
  height: 34px;
  transition: border var(--transition);
}
.exercise-block-note:focus { outline: none; border-color: var(--primary); }
.exercise-block-note::placeholder { color: var(--gray-300); }
.exercise-block-rest {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
  font-size: .82rem;
  color: var(--gray-500);
}
.exercise-block-rest select {
  padding: 6px 10px;
  border: 1.5px solid var(--gray-200);
  border-radius: var(--radius-xs);
  font-family: inherit;
  font-size: .84rem;
  font-weight: 600;
  color: var(--gray-700);
  background: white;
  cursor: pointer;
}
.set-table { width: 100%; border-collapse: collapse; }
.set-table th {
  font-size: .7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .5px;
  color: var(--gray-400);
  text-align: center;
  padding: 0 4px 8px;
}
.set-table th:first-child { text-align: left; width: 40px; }
.set-table td {
  padding: 3px 3px;
  text-align: center;
  vertical-align: middle;
}
.set-table td:first-child { text-align: left; }
.set-number {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--gray-100);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: .82rem;
  font-weight: 700;
  color: var(--gray-600);
}
.set-input {
  width: 100%;
  max-width: 64px;
  padding: 7px 6px;
  border: 1.5px solid var(--gray-200);
  border-radius: var(--radius-xs);
  font-family: inherit;
  font-size: .87rem;
  font-weight: 600;
  color: var(--gray-700);
  text-align: center;
  background: white;
  transition: border var(--transition);
}
.set-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 2px rgba(14,165,233,.12); }
.set-input-sm { max-width: 48px; }
.rep-range-cell {
  display: flex;
  align-items: center;
  gap: 3px;
  justify-content: center;
}
.rep-range-cell span {
  font-size: .82rem;
  color: var(--gray-400);
}
.rpe-select {
  padding: 7px 6px;
  border: 1.5px solid var(--gray-200);
  border-radius: var(--radius-xs);
  font-family: inherit;
  font-size: .87rem;
  font-weight: 600;
  color: var(--gray-700);
  background: white;
  cursor: pointer;
  width: 64px;
  text-align: center;
}
.set-delete {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: none;
  background: transparent;
  color: var(--gray-300);
  cursor: pointer;
  font-size: .9rem;
  display: flex;
  align-items: center;
  justify-content: center;
}
.set-delete:hover { background: var(--danger-light); color: var(--danger); }
.add-set-btn {
  display: block;
  width: 100%;
  padding: 8px;
  background: transparent;
  border: none;
  color: var(--primary);
  font-family: inherit;
  font-size: .84rem;
  font-weight: 600;
  cursor: pointer;
  margin-top: 4px;
  border-radius: var(--radius-xs);
}
.add-set-btn:hover { background: var(--primary-light); }

/* Legacy exercise row */
.exercise-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  background: var(--gray-50);
  border-radius: var(--radius-sm);
  margin-bottom: 8px;
  transition: box-shadow var(--transition);
}
.exercise-row:hover { box-shadow: var(--shadow); }
.ex-drag { color: var(--gray-300); cursor: grab; font-size: 1.1rem; }
.ex-icon { font-size: 1.1rem; }
.ex-info { flex: 1; }
.ex-name { font-weight: 600; font-size: .92rem; color: var(--gray-800); }
.ex-meta { font-size: .77rem; color: var(--gray-400); margin-top: 2px; }
.ex-config { font-size: .84rem; font-weight: 600; color: var(--gray-600); white-space: nowrap; }
.ex-rpe { font-size: .77rem; color: var(--warning); font-weight: 700; background: var(--warning-light); padding: 2px 8px; border-radius: 12px; }

.session-card {
  padding: 20px 24px;
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 14px;
  cursor: pointer;
  transition: all var(--transition);
  border-left: 4px solid var(--primary);
}
.session-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
.session-card h3 { font-size: .97rem; font-weight: 700; color: var(--gray-800); margin-bottom: 4px; }
.session-card .sc-meta { font-size: .8rem; color: var(--gray-400); font-weight: 500; }
.session-card .sc-exercises { font-size: .82rem; color: var(--gray-500); margin-top: 8px; line-height: 1.5; }

.alert-card {
  padding: 14px 18px;
  border-radius: var(--radius-sm);
  font-size: .84rem;
  font-weight: 500;
  margin-top: 12px;
}
.alert-warning { background: var(--warning-light); color: #92400E; }
.alert-info { background: var(--primary-light); color: var(--primary-dark); }
.alert-success { background: var(--success-light); color: #065F46; }

.comparison-table { width: 100%; font-size: .87rem; border-collapse: collapse; }
.comparison-table th { padding: 10px 12px; text-align: left; color: var(--gray-400); font-weight: 600; font-size: .77rem; text-transform: uppercase; border-bottom: 2px solid var(--gray-100); }
.comparison-table td { padding: 10px 12px; border-bottom: 1px solid var(--gray-50); }

.pr-card {
  padding: 18px 22px;
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 12px;
  display: flex;
  gap: 14px;
  align-items: flex-start;
}
.pr-medal { font-size: 1.5rem; flex-shrink: 0; margin-top: 2px; }
.pr-info { flex: 1; }
.pr-name { font-weight: 700; font-size: .94rem; color: var(--gray-800); }
.pr-detail { font-size: .84rem; color: var(--gray-500); margin-top: 3px; }
.pr-trend { font-size: .8rem; margin-top: 4px; font-weight: 500; }
.pr-badge-new {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  color: #fff;
  font-size: .7rem;
  font-weight: 700;
  margin-left: 6px;
}

.timeline-item {
  position: relative;
  padding-left: 28px;
  padding-bottom: 28px;
  border-left: 2px solid var(--gray-200);
  margin-left: 8px;
}
.timeline-item:last-child { border-left-color: transparent; }
.timeline-dot {
  position: absolute;
  left: -7px; top: 2px;
  width: 12px; height: 12px;
  border-radius: 50%;
  background: var(--primary);
  border: 2px solid var(--card);
}
.timeline-item.faded .timeline-dot { background: var(--gray-300); }
.timeline-date { font-size: .77rem; color: var(--gray-400); font-weight: 600; margin-bottom: 4px; }
.timeline-content { font-size: .87rem; color: var(--gray-600); }

.border-card {
  border-left: 4px solid var(--success);
  padding: 18px 22px;
  background: var(--card);
  border-radius: 0 var(--radius) var(--radius) 0;
  box-shadow: var(--shadow);
  margin-bottom: 18px;
}

.wizard-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,.4);
  z-index: 500;
  justify-content: center;
  align-items: center;
}
.wizard-overlay.open { display: flex; }
.wizard-panel {
  background: var(--card);
  border-radius: var(--radius);
  width: 520px;
  max-width: 95vw;
  max-height: 85vh;
  overflow-y: auto;
  padding: 32px;
  box-shadow: var(--shadow-lg);
  animation: fadeScale .25s ease;
}

/* LOGIN SCREEN */
.login-screen {
  position: fixed; inset: 0; z-index: 9999;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #0369A1 0%, #0EA5E9 50%, #06B6D4 100%);
  transition: opacity .5s ease, transform .5s ease;
}
.login-screen.hidden { opacity: 0; transform: scale(1.02); pointer-events: none; }
.login-card {
  background: var(--card);
  border-radius: 20px;
  padding: 48px 40px;
  width: 420px;
  max-width: 92vw;
  box-shadow: 0 20px 60px rgba(0,0,0,.2);
  text-align: center;
  animation: fadeScale .4s ease;
}
.login-logo {
  font-size: 2rem; font-weight: 800; color: var(--gray-800); margin-bottom: 6px;
}
.login-logo span { color: var(--primary); }
.login-subtitle { color: var(--gray-500); font-size: .9rem; margin-bottom: 32px; }
.login-input {
  width: 100%; padding: 14px 18px; border: 1.5px solid var(--gray-200);
  border-radius: 12px; font-size: 1rem; text-align: center;
  transition: border-color .2s, box-shadow .2s;
}
.login-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(14,165,233,.15); outline: none; }
.login-btn {
  width: 100%; padding: 14px; border-radius: 12px; border: none;
  background: var(--primary); color: #fff; font-weight: 700; font-size: 1rem;
  cursor: pointer; margin-top: 16px; transition: background .2s, transform .1s;
}
.login-btn:hover { background: var(--primary-dark); }
.login-btn:active { transform: scale(.98); }
.login-btn:disabled { opacity: .6; cursor: not-allowed; }
.login-divider { color: var(--gray-400); font-size: .8rem; margin: 20px 0; }
.login-alt { color: var(--gray-500); font-size: .85rem; }
.login-alt a { color: var(--primary); font-weight: 600; cursor: pointer; }

/* Login check inbox state */
.login-inbox { display: none; text-align: center; }
.login-inbox .inbox-icon { font-size: 3rem; margin-bottom: 12px; }
.login-inbox h3 { font-weight: 700; margin-bottom: 8px; }
.login-inbox p { color: var(--gray-500); font-size: .9rem; line-height: 1.5; }
.login-inbox .resend-link { color: var(--primary); cursor: pointer; font-weight: 600; font-size: .85rem; margin-top: 16px; display: inline-block; }

/* MULTI-STEP WIZARD */
.wizard-steps {
  display: flex; align-items: center; gap: 0; margin-bottom: 28px;
}
.wizard-step-dot {
  width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: .8rem; font-weight: 700; border: 2px solid var(--gray-200); color: var(--gray-400); background: var(--card);
  transition: all .2s; flex-shrink: 0;
}
.wizard-step-dot.active { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }
.wizard-step-dot.done { border-color: var(--success); background: var(--success); color: #fff; }
.wizard-step-line { flex: 1; height: 2px; background: var(--gray-200); transition: background .2s; }
.wizard-step-line.done { background: var(--success); }
.wizard-step-label { font-size: .7rem; color: var(--gray-400); text-align: center; margin-top: 4px; }
.wizard-step-label.active { color: var(--primary); font-weight: 600; }
.wizard-step-label.done { color: var(--success); }

.wizard-step-content { display: none; animation: fadeIn .3s ease; }
.wizard-step-content.active { display: block; }

.wizard-footer { display: flex; gap: 10px; margin-top: 24px; }
.wizard-footer .btn { flex: 1; }

/* Volume target rows */
.vol-target-row {
  display: flex; align-items: center; gap: 8px; padding: 8px 0;
  border-bottom: 1px solid var(--gray-100);
}
.vol-target-row:last-child { border-bottom: none; }
.vol-target-muscle { width: 100px; font-weight: 600; font-size: .85rem; }
.vol-target-inputs { display: flex; gap: 6px; flex: 1; }
.vol-target-inputs input {
  width: 60px; padding: 6px 8px; text-align: center; font-size: .85rem;
  border: 1.5px solid var(--gray-200); border-radius: var(--radius-xs);
}
.vol-target-inputs input:focus { border-color: var(--primary); }
.vol-target-label { font-size: .7rem; color: var(--gray-400); text-align: center; }

/* Macro toggle */
.macro-toggle {
  display: inline-flex; border-radius: 8px; border: 1.5px solid var(--gray-200); overflow: hidden; margin-bottom: 12px;
}
.macro-toggle button {
  padding: 6px 16px; font-size: .8rem; font-weight: 600; color: var(--gray-500);
  background: var(--card); border: none; cursor: pointer; transition: all .2s;
}
.macro-toggle button.active { background: var(--primary); color: #fff; }

/* Exit criteria chips (configurable) */
.exit-criteria-item {
  display: flex; align-items: center; gap: 12px; padding: 12px 14px;
  background: var(--gray-50); border-radius: var(--radius-sm); margin-bottom: 8px;
}
.exit-criteria-item .toggle-switch {
  width: 40px; height: 22px; background: var(--gray-200); border-radius: 11px;
  position: relative; cursor: pointer; transition: background .2s; flex-shrink: 0;
}
.exit-criteria-item .toggle-switch.on { background: var(--primary); }
.exit-criteria-item .toggle-switch::after {
  content: ''; position: absolute; top: 2px; left: 2px;
  width: 18px; height: 18px; background: #fff; border-radius: 50%;
  transition: transform .2s;
}
.exit-criteria-item .toggle-switch.on::after { transform: translateX(18px); }
.exit-criteria-desc { flex: 1; }
.exit-criteria-desc .ec-title { font-weight: 600; font-size: .85rem; }
.exit-criteria-desc .ec-sub { font-size: .78rem; color: var(--gray-500); }

/* Review summary */
.review-section { margin-bottom: 16px; }
.review-section h4 { font-size: .8rem; color: var(--gray-500); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 8px; }
.review-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 16px; }
.review-item { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--gray-100); }
.review-item .ri-label { color: var(--gray-500); font-size: .85rem; }
.review-item .ri-value { font-weight: 600; font-size: .85rem; }

/* Panel section title */
.panel-title {
  font-weight: 700;
  font-size: 1rem;
  color: var(--gray-800);
  margin-bottom: 18px;
}

/* SVG Sparkline charts */
.sparkline-container {
  padding: 4px 0;
}
.sparkline-container svg {
  width: 100%;
  height: 60px;
}

/* Phase card styles */
.phase-card-active {
  background: linear-gradient(135deg, var(--primary-light), #E0F7FA);
  border: 2px solid var(--primary);
  border-radius: var(--radius);
  padding: 26px 28px;
  margin-bottom: 18px;
  position: relative;
}
.phase-card-past {
  background: var(--card);
  border: 1.5px solid var(--gray-200);
  border-radius: var(--radius);
  padding: 20px 24px;
  margin-bottom: 12px;
  transition: all var(--transition);
}
.phase-card-past:hover { box-shadow: var(--shadow-md); }

/* Routine card for plan overview (Hevy Coach style) */
.routine-card {
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 16px;
  overflow: hidden;
  cursor: pointer;
  transition: all var(--transition);
  border-left: 4px solid var(--primary);
}
.routine-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
.routine-card-header {
  padding: 20px 24px 12px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.routine-card-exercises {
  padding: 0 24px 16px;
}
.routine-exercise-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 6px 0;
  font-size: .84rem;
  color: var(--gray-600);
  border-bottom: 1px solid var(--gray-50);
}
.routine-exercise-item:last-child { border-bottom: none; }
.routine-exercise-item .re-icon {
  width: 28px; height: 28px;
  border-radius: 6px;
  background: var(--gray-50);
  display: flex; align-items: center; justify-content: center;
  font-size: .8rem;
  flex-shrink: 0;
}
.routine-exercise-item .re-name { flex: 1; font-weight: 500; }
.routine-exercise-item .re-config { color: var(--gray-400); font-size: .77rem; font-weight: 600; }

/* Training insight item */
.insight-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 18px;
  background: var(--card);
  border-radius: var(--radius-sm);
  margin-bottom: 8px;
  box-shadow: var(--shadow);
}
.insight-icon {
  width: 38px; height: 38px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}
.insight-icon-up { background: var(--success-light); }
.insight-icon-stall { background: var(--warning-light); }
.insight-icon-down { background: var(--danger-light); }
.insight-info { flex: 1; }
.insight-name { font-weight: 600; font-size: .9rem; color: var(--gray-800); }
.insight-detail { font-size: .78rem; color: var(--gray-500); margin-top: 2px; }

.text-xs { font-size: .77rem; }
.text-sm { font-size: .84rem; }
.text-muted { color: var(--gray-400); }
.text-success { color: var(--success); }
.text-warning { color: var(--warning); }
.text-danger { color: var(--danger); }
.font-bold { font-weight: 700; }
.font-extrabold { font-weight: 800; }
.mt-1 { margin-top: 8px; }
.mt-2 { margin-top: 16px; }
.mt-3 { margin-top: 24px; }
.mb-1 { margin-bottom: 8px; }
.mb-2 { margin-bottom: 16px; }
.mb-3 { margin-bottom: 24px; }
.flex { display: flex; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.gap-1 { gap: 8px; }
.gap-2 { gap: 16px; }
.gap-3 { gap: 24px; }
.flex-wrap { flex-wrap: wrap; }
.w-full { width: 100%; }
.text-right { text-align: right; }
.inline-flex { display: inline-flex; }

/* Session switcher pills */
.session-pill {
  padding: 7px 16px;
  border-radius: 20px;
  border: 1.5px solid var(--gray-200);
  font-size: .84rem;
  font-weight: 600;
  color: var(--gray-500);
  background: var(--card);
  cursor: pointer;
  transition: all var(--transition);
}
.session-pill:hover { border-color: var(--primary); color: var(--primary); }
.session-pill.active {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
}

/* ============================================================
   EXERCISE LIBRARY (Right Panel)
   ============================================================ */
#planPanelExercises .ex-lib-header {
  font-size: .82rem;
  font-weight: 600;
  color: var(--gray-500);
  text-transform: uppercase;
  letter-spacing: .04em;
  margin-bottom: 12px;
}
.ex-lib-plus-link {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--primary);
  font-weight: 600;
  font-size: .9rem;
  cursor: pointer;
  padding: 8px 0;
  margin-bottom: 8px;
}
.ex-lib-plus-link:hover { opacity: .8; }
.ex-lib-search-wrap {
  position: relative;
  margin-bottom: 10px;
}
.ex-lib-search-wrap .search-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--gray-400);
  font-size: .9rem;
  pointer-events: none;
}
.ex-lib-list {
  overflow-y: auto;
  max-height: calc(100vh - 340px);
  margin: 0 -20px;
  padding: 0 20px;
}
.ex-lib-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background var(--transition);
  position: relative;
}
.ex-lib-item:hover {
  background: var(--gray-50);
}
.ex-lib-plus {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--primary);
  color: white;
  font-size: 1rem;
  font-weight: 700;
  flex-shrink: 0;
  line-height: 1;
}
.ex-lib-icon {
  font-size: 1.2rem;
  width: 28px;
  text-align: center;
  flex-shrink: 0;
}
.ex-lib-info {
  flex: 1;
  min-width: 0;
}
.ex-lib-name {
  font-weight: 600;
  font-size: .88rem;
  color: var(--gray-800);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.ex-lib-meta {
  font-size: .78rem;
  color: var(--gray-400);
  margin-top: 1px;
}
</style>
</head>
<body>

<!-- ============================================================
     LOGIN SCREEN
     ============================================================ -->
<div class="login-screen hidden" id="loginScreen" style="display:none;">
  <div class="login-card">
    <!-- Email Form -->
    <div id="loginForm">
      <div class="login-logo">Fit<span>OS</span></div>
      <div class="login-subtitle">Your personal training brain</div>

      <input class="login-input" type="email" id="loginEmail" placeholder="your@email.com" autocomplete="email">
      <button class="login-btn" id="loginBtn" onclick="sendMagicLink()">Send Magic Link</button>

      <div class="login-divider">No password needed</div>
      <div class="login-alt">We'll send a secure link to your email.<br>Click it to log in instantly.</div>
    </div>

    <!-- Check Inbox State -->
    <div class="login-inbox" id="loginInbox">
      <div class="inbox-icon">&#x2709;&#xFE0F;</div>
      <h3>Check your inbox</h3>
      <p>We sent a magic link to<br><strong id="loginSentEmail">your@email.com</strong></p>
      <p style="margin-top:12px;font-size:.82rem;color:var(--gray-400);">Click the link in the email to sign in.<br>Check spam if you don't see it.</p>
      <span class="resend-link" onclick="resendMagicLink()">Resend email</span>
      <div style="margin-top:20px;">
        <button class="login-btn" style="background:var(--gray-100);color:var(--gray-700);font-weight:600;" onclick="backToLoginForm()">&#8592; Use a different email</button>
      </div>
      <!-- Demo skip button -->
      <div style="margin-top:16px;">
        <span style="color:var(--primary);cursor:pointer;font-size:.82rem;font-weight:600;" onclick="skipLogin()">Skip for demo &#8594;</span>
      </div>
    </div>
  </div>

  <!-- Decorative elements -->
  <div style="position:absolute;bottom:24px;color:rgba(255,255,255,.5);font-size:.78rem;">
    Built for one. Powered by data. Coached by AI.
  </div>
</div>

<!-- ============================================================
     APP SHELL
     ============================================================ -->
<div class="app-shell" id="appShell">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <!-- NORMAL NAV -->
    <div id="sidebarNav">
      <div class="sidebar-logo">Fit<span>OS</span></div>
      <div class="sidebar-divider"></div>
      <nav class="sidebar-nav">
        <div class="nav-item active" onclick="switchTab('dashboard')">
          <span class="nav-icon">&#x1F4CA;</span> Dashboard
        </div>
        <div class="nav-item" onclick="switchTab('plan')">
          <span class="nav-icon">&#x1F4CB;</span> Plan
        </div>
        <div class="nav-item" onclick="switchTab('progress')">
          <span class="nav-icon">&#x1F4C8;</span> Progress
        </div>
        <div class="nav-item" onclick="switchTab('journal')">
          <span class="nav-icon">&#x1F4D3;</span> Journal
        </div>
        <div class="nav-item" onclick="switchTab('learn')">
          <span class="nav-icon">&#x1F4DA;</span> Learn
        </div>
      </nav>
      <div class="sidebar-divider"></div>
      <div class="sidebar-user" onclick="showProfile()">
        <div class="user-avatar">N</div>
        <div class="user-info">
          <div class="user-name">Natali</div>
          <div class="user-role">Training since 2024</div>
        </div>
      </div>
    </div>

    <!-- (exercise library is in right panel, not sidebar) -->
  </aside>

  <!-- MAIN AREA -->
  <div class="main-area" id="mainArea">

    <!-- ============================================================
         1. DASHBOARD
         ============================================================ -->
    <div class="main-content" id="dashboardWrapper">
      <div class="screen active" id="screen-dashboard">
        <div class="page-header">
          <h1>Dashboard</h1>
          <p>Quick glance at your week</p>
        </div>

        <!-- A. Week Status Bar -->
        <div class="gradient-card fade-in">
          <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
            <div>
              <div style="font-weight:800;font-size:1.15rem;">Week 1 of 6</div>
              <div style="opacity:.85;font-size:.87rem;">Definicion Q1</div>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <span class="pill">&#x1F3CB;&#xFE0F; 2/3 sessions</span>
              <span class="pill">&#x1F4DD; 5/7 daily logs</span>
              <span class="pill">&#x1F4CA; Check-in: pending</span>
            </div>
          </div>
          <div style="margin-top:16px;display:flex;gap:14px;">
            <div style="flex:1;">
              <div style="font-size:.72rem;opacity:.7;margin-bottom:5px;">Sessions</div>
              <div class="progress-bar" style="background:rgba(255,255,255,.2);"><div class="fill" style="width:67%;background:#fff;"></div></div>
            </div>
            <div style="flex:1;">
              <div style="font-size:.72rem;opacity:.7;margin-bottom:5px;">Daily logs</div>
              <div class="progress-bar" style="background:rgba(255,255,255,.2);"><div class="fill" style="width:71%;background:#fff;"></div></div>
            </div>
            <div style="flex:1;">
              <div style="font-size:.72rem;opacity:.7;margin-bottom:5px;">Check-in</div>
              <div class="progress-bar" style="background:rgba(255,255,255,.2);"><div class="fill" style="width:0%;background:#fff;"></div></div>
            </div>
          </div>
        </div>

        <!-- B. Two-column layout: Up Next + Active Phase -->
        <div class="grid-2 fade-in" style="animation-delay:.05s;">
          <!-- Up Next -->
          <div class="card card-sm">
            <div class="section-title" style="margin-bottom:8px;">&#x1F4C5; Up Next</div>
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <div>
                <div style="font-weight:600;font-size:.94rem;">Day C: Volumen</div>
                <div class="text-sm text-muted">Suggested: tomorrow</div>
              </div>
              <span class="badge badge-blue">1 session left</span>
            </div>
          </div>

          <!-- Active Phase -->
          <div class="card card-sm" style="cursor:pointer;" onclick="switchTab('plan');switchPlanTab('phase');">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
              <div style="flex:1;">
                <div style="display:flex;align-items:center;gap:8px;">
                  <div style="font-weight:700;font-size:.98rem;color:var(--gray-800);">Definicion Q1</div>
                  <span class="badge badge-green" style="font-size:.68rem;">On Track</span>
                </div>
                <div style="margin-top:6px;font-size:.82rem;color:var(--gray-500);font-style:italic;line-height:1.4;">&#x1F3AF; Llegar a 52.5kg, cintura &lt;66cm. Mantener fuerza en compuestos.</div>
              </div>
              <span style="color:var(--gray-300);font-size:.9rem;margin-left:8px;">&#x203A;</span>
            </div>
            <div style="margin-top:10px;">
              <div style="display:flex;justify-content:space-between;font-size:.78rem;color:var(--gray-500);margin-bottom:4px;">
                <span>Week 1 of 6</span><span>17%</span>
              </div>
              <div class="progress-bar"><div class="fill fill-blue" style="width:17%;"></div></div>
            </div>
          </div>
        </div>

        <!-- C. Three-column: Key metrics -->
        <div class="grid-3 fade-in" style="animation-delay:.1s;">
          <div class="card card-sm" style="text-align:center;">
            <div class="text-xs text-muted" style="margin-bottom:2px;">Weight</div>
            <div style="font-size:1.25rem;font-weight:800;color:var(--gray-800);">53.7 kg</div>
            <div style="font-size:.8rem;color:var(--success);font-weight:600;">&#x2193; 0.4 kg</div>
          </div>
          <div class="card card-sm" style="text-align:center;">
            <div class="text-xs text-muted" style="margin-bottom:2px;">Waist</div>
            <div style="font-size:1.25rem;font-weight:800;color:var(--gray-800);">67.5 cm</div>
            <div style="font-size:.8rem;color:var(--success);font-weight:600;">&#x2193; 0.5 cm</div>
          </div>
          <div class="card card-sm" style="text-align:center;">
            <div class="text-xs text-muted" style="margin-bottom:2px;">Adherence</div>
            <div style="font-size:1.25rem;font-weight:800;color:var(--gray-800);">97%</div>
            <div style="font-size:.8rem;color:var(--success);font-weight:600;">72/74 sets</div>
          </div>
        </div>

        <!-- D. Insight -->
        <div class="fade-in" style="animation-delay:.15s;">
          <div class="card card-sm" style="border-left:4px solid var(--warning);">
            <div style="font-weight:600;font-size:.9rem;color:var(--gray-800);">&#x26A0;&#xFE0F; Glute volume gap</div>
            <div class="text-sm text-muted mt-1">6 sets below weekly target. Consider adding Hip Abduction or Cable Kickbacks to Day C.</div>
            <button class="btn btn-sm btn-outline mt-2" onclick="switchTab('plan')">Fix in Planner</button>
          </div>
        </div>

        <!-- Check-in CTA -->
        <div class="gradient-card-dark fade-in" style="animation-delay:.18s;display:flex;align-items:center;justify-content:space-between;gap:16px;">
          <div>
            <div style="font-weight:700;font-size:1rem;">&#x1F4CB; Weekly Check-in</div>
            <div style="font-size:.84rem;opacity:.8;margin-top:4px;">Week 1 — Not completed yet</div>
          </div>
          <button class="btn" style="background:#fff;color:var(--primary-dark);font-weight:700;white-space:nowrap;" onclick="openCheckinOverlay()">Do Check-in</button>
        </div>

        <!-- E. Daily Averages mini-table -->
        <div class="card fade-in" style="animation-delay:.2s;overflow-x:auto;">
          <div class="section-title" style="margin-bottom:10px;">&#x1F4CA; This Week's Daily Logs</div>
          <table class="mini-table">
            <thead>
              <tr><th></th><th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th><th>Sun</th><th style="color:var(--primary);">Avg</th></tr>
            </thead>
            <tbody>
              <tr><td style="text-align:left;font-weight:600;color:var(--gray-500);font-size:.72rem;">Cal</td><td>1620</td><td>1580</td><td>1700</td><td>1650</td><td>&mdash;</td><td>&mdash;</td><td>&mdash;</td><td style="font-weight:700;color:var(--gray-800);">1638</td></tr>
              <tr><td style="text-align:left;font-weight:600;color:var(--gray-500);font-size:.72rem;">Prot</td><td>118</td><td>122</td><td>115</td><td>120</td><td>&mdash;</td><td>&mdash;</td><td>&mdash;</td><td style="font-weight:700;color:var(--gray-800);">119g</td></tr>
              <tr><td style="text-align:left;font-weight:600;color:var(--gray-500);font-size:.72rem;">Steps</td><td>8.2k</td><td>9.1k</td><td>7.5k</td><td>8.0k</td><td>&mdash;</td><td>&mdash;</td><td>&mdash;</td><td style="font-weight:700;color:var(--gray-800);">8.2k</td></tr>
              <tr><td style="text-align:left;font-weight:600;color:var(--gray-500);font-size:.72rem;">Energy</td><td>3</td><td>3</td><td>2</td><td>3</td><td>&mdash;</td><td>&mdash;</td><td>&mdash;</td><td style="font-weight:700;color:var(--gray-800);">2.8</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- DASHBOARD RIGHT PANEL -->
    <div class="right-panel" id="dashboardPanel">
      <!-- Weekly Score -->
      <div class="gradient-card-dark" style="margin:-8px -4px 0;padding:26px;border-radius:var(--radius);">
        <div style="text-align:center;">
          <div class="score-ring" style="margin:0 auto 12px;">
            <svg viewBox="0 0 100 100">
              <circle cx="50" cy="50" r="42" fill="none" stroke="rgba(255,255,255,.15)" stroke-width="8"/>
              <circle cx="50" cy="50" r="42" fill="none" stroke="#06B6D4" stroke-width="8" stroke-dasharray="264" stroke-dashoffset="32" stroke-linecap="round"/>
            </svg>
            <span class="score-val" style="color:#fff;">88</span>
          </div>
          <div style="font-weight:800;font-size:1.02rem;">Great week!</div>
          <div style="font-size:.8rem;opacity:.7;margin-top:4px;">Weekly Score</div>
        </div>
        <div style="margin-top:18px;display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          <div style="text-align:center;background:rgba(255,255,255,.08);border-radius:10px;padding:10px;">
            <div style="font-size:.7rem;opacity:.6;">Training</div>
            <div style="font-weight:800;font-size:1.05rem;">97%</div>
          </div>
          <div style="text-align:center;background:rgba(255,255,255,.08);border-radius:10px;padding:10px;">
            <div style="font-size:.7rem;opacity:.6;">Nutrition</div>
            <div style="font-weight:800;font-size:1.05rem;">94%</div>
          </div>
          <div style="text-align:center;background:rgba(255,255,255,.08);border-radius:10px;padding:10px;">
            <div style="font-size:.7rem;opacity:.6;">Steps</div>
            <div style="font-weight:800;font-size:1.05rem;">82%</div>
          </div>
          <div style="text-align:center;background:rgba(255,255,255,.08);border-radius:10px;padding:10px;">
            <div style="font-size:.7rem;opacity:.6;">Sleep</div>
            <div style="font-weight:800;font-size:1.05rem;">95%</div>
          </div>
        </div>
      </div>

      <!-- AI Gym Suggestions -->
      <div class="border-card" style="margin-top:24px;margin-bottom:0;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
          <div class="panel-title" style="margin-bottom:0;">&#x1F4A1; Next Session Tips</div>
        </div>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <div style="padding:10px 12px;background:var(--success-light);border-radius:var(--radius-xs);font-size:.84rem;">
            <div style="font-weight:600;color:#065F46;margin-bottom:2px;">&#x2B06; Hip Thrust: Try 72.5kg</div>
            <div style="color:#065F46;opacity:.8;">Last 3 sessions at RPE 8 with 70kg. Ready to progress.</div>
          </div>
          <div style="padding:10px 12px;background:var(--success-light);border-radius:var(--radius-xs);font-size:.84rem;">
            <div style="font-weight:600;color:#065F46;margin-bottom:2px;">&#x2B06; Lat Pulldown: Try 47.5kg</div>
            <div style="color:#065F46;opacity:.8;">Hit all reps at RPE 7.5. Time to increase.</div>
          </div>
          <div style="padding:10px 12px;background:var(--warning-light);border-radius:var(--radius-xs);font-size:.84rem;">
            <div style="font-weight:600;color:#92400E;margin-bottom:2px;">&#x23F8; Squat (Smith): Maintain 50kg</div>
            <div style="color:#92400E;opacity:.8;">Stalled 3 weeks. Consider form check or deload.</div>
          </div>
          <div style="padding:10px 12px;background:var(--primary-light);border-radius:var(--radius-xs);font-size:.84rem;">
            <div style="font-weight:600;color:var(--primary-dark);margin-bottom:2px;">&#x1F3AF; Focus: Add glute volume</div>
            <div style="color:var(--primary-dark);opacity:.8;">6 sets below target. Add 2 sets of Cable Kickback.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ============================================================
         2. PLAN
         ============================================================ -->
    <div class="main-content" id="planWrapper" style="display:none;">
      <div class="screen active" id="screen-plan">

        <!-- PLAN SUB-TABS -->
        <div id="planSubTabs" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
          <div class="tab-bar" style="margin-bottom:0;display:inline-flex;">
            <div class="tab-btn active" id="planTabRoutines" onclick="switchPlanTab('routines')">Routines</div>
            <div class="tab-btn" id="planTabPhase" onclick="switchPlanTab('phase')">Current Phase</div>
          </div>
          <button class="mobile-stats-btn" onclick="openStatsDrawer()">&#x1F4CA; View Stats</button>
        </div>

        <!-- PLAN HOME: ROUTINES VIEW -->
        <div id="planHome">

          <!-- Program Title & Note (Hevy Coach style) -->
          <div class="card" style="margin-bottom:24px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
              <div>
                <div style="font-weight:800;font-size:1.1rem;color:var(--gray-900);">Definicion Q1</div>
                <div style="display:flex;gap:8px;margin-top:6px;flex-wrap:wrap;">
                  <span class="badge badge-yellow">Goal: Cut / Define</span>
                  <span class="badge badge-blue">1,650 kcal</span>
                  <span class="badge badge-blue">120g protein</span>
                  <span class="badge badge-gray">3x/week</span>
                </div>
              </div>
              <button class="btn btn-sm btn-outline" onclick="showEditPhaseWizard()">&#x270F;&#xFE0F; Edit</button>
            </div>
            <textarea class="exercise-block-note" style="height:42px;width:100%;margin-bottom:0;" placeholder="Program note...">Focus on progressive overload for glutes and back. Maintain strength in compounds during cut.</textarea>
          </div>

          <!-- Routines header -->
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div class="section-title" style="margin-bottom:0;">Routines (3)</div>
            <button class="btn btn-sm btn-primary" onclick="showToast('New routine created!');showSessionEditor('a');">+ Add Routine</button>
          </div>

          <!-- Routine Cards (Hevy Coach style with exercises visible) -->
          <div class="routine-card" onclick="showSessionEditor('a')">
            <div class="routine-card-header">
              <div>
                <h3 style="font-size:1rem;font-weight:700;color:var(--gray-800);margin-bottom:2px;">Dia 1: Fuerza</h3>
                <div class="text-xs text-muted">7 exercises &middot; 25 sets &middot; ~75 min</div>
              </div>
              <span style="color:var(--gray-300);font-size:1.1rem;">&#x203A;</span>
            </div>
            <div class="routine-card-exercises">
              <div class="routine-exercise-item"><div class="re-icon">&#x1F3CB;&#xFE0F;</div><span class="re-name">Hip Thrust (Barbell)</span><span class="re-config">4x5-7</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F4AA;</div><span class="re-name">Lat Pulldown (Cable)</span><span class="re-config">3x8-10</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F9CE;</div><span class="re-name">Squat (Smith Machine)</span><span class="re-config">4x6-8</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F3CB;&#xFE0F;</div><span class="re-name">Bench Press (Barbell)</span><span class="re-config">3x6-8</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F9B5;</div><span class="re-name">Romanian Deadlift</span><span class="re-config">4x8-10</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F9B5;</div><span class="re-name">Hip Abduction (Machine)</span><span class="re-config">3x12-15</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F9D8;</div><span class="re-name">Plank</span><span class="re-config">3x45s</span></div>
            </div>
          </div>

          <div class="routine-card" onclick="showSessionEditor('b')" style="border-left-color:var(--accent);">
            <div class="routine-card-header">
              <div>
                <h3 style="font-size:1rem;font-weight:700;color:var(--gray-800);margin-bottom:2px;">Dia B: Hipertrofia</h3>
                <div class="text-xs text-muted">7 exercises &middot; 23 sets &middot; ~70 min</div>
              </div>
              <span style="color:var(--gray-300);font-size:1.1rem;">&#x203A;</span>
            </div>
            <div class="routine-card-exercises">
              <div class="routine-exercise-item"><div class="re-icon">&#x1F3CB;&#xFE0F;</div><span class="re-name">Hip Thrust (Barbell)</span><span class="re-config">3x12</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F4AA;</div><span class="re-name">Neg. Pull Up</span><span class="re-config">4x6</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F9CE;</div><span class="re-name">Reverse Lunge (DB)</span><span class="re-config">3x10</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F4AA;</div><span class="re-name">Cable Row</span><span class="re-config">4x12</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F9B5;</div><span class="re-name">Leg Curl (Machine)</span><span class="re-config">3x12</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F3CB;&#xFE0F;</div><span class="re-name">OH Press (DB)</span><span class="re-config">3x10</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F4AA;</div><span class="re-name">Bicep Curl (DB)</span><span class="re-config">3x12</span></div>
            </div>
          </div>

          <div class="routine-card" onclick="showSessionEditor('c')" style="border-left-color:var(--success);">
            <div class="routine-card-header">
              <div>
                <h3 style="font-size:1rem;font-weight:700;color:var(--gray-800);margin-bottom:2px;">Dia C: Volumen</h3>
                <div class="text-xs text-muted">7 exercises &middot; 26 sets &middot; ~80 min</div>
              </div>
              <span style="color:var(--gray-300);font-size:1.1rem;">&#x203A;</span>
            </div>
            <div class="routine-card-exercises">
              <div class="routine-exercise-item"><div class="re-icon">&#x1F9B5;</div><span class="re-name">Romanian Deadlift</span><span class="re-config">4x10</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F3CB;&#xFE0F;</div><span class="re-name">Lateral Raise (DB)</span><span class="re-config">4x15</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F4AA;</div><span class="re-name">Bicep Curl (Cable)</span><span class="re-config">3x12</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F9B5;</div><span class="re-name">Hip Abduction (Machine)</span><span class="re-config">3x15</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F9D8;</div><span class="re-name">Plank</span><span class="re-config">3x45s</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F9B5;</div><span class="re-name">Cable Kickback</span><span class="re-config">3x12</span></div>
              <div class="routine-exercise-item"><div class="re-icon">&#x1F4AA;</div><span class="re-name">Tricep Pushdown</span><span class="re-config">3x12</span></div>
            </div>
          </div>
        </div>

        <!-- PLAN: PHASE VIEW (inside Plan tab) -->
        <div id="planPhaseView" style="display:none;">
          <!-- Active Phase (Prominent) -->
          <div class="phase-card-active fade-in">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;">
              <div>
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                  <span class="badge badge-blue" style="font-size:.8rem;padding:4px 14px;">Active Phase</span>
                </div>
                <div style="font-weight:800;font-size:1.3rem;color:var(--gray-900);margin-bottom:4px;">Definicion Q1</div>
                <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;">
                  <span class="badge badge-yellow">Cut / Define</span>
                  <span class="badge badge-gray">3x/week</span>
                  <span class="badge badge-gray">Glutes, Back</span>
                  <span class="badge badge-gray">1,650 kcal / 120g P</span>
                </div>
              </div>
              <div style="display:flex;gap:8px;">
                <button class="btn btn-sm btn-outline" onclick="showEditPhaseWizard()">&#x270F;&#xFE0F; Edit</button>
                <button class="btn btn-sm btn-danger-outline" onclick="showEndPhaseFlow()">End Phase</button>
              </div>
            </div>

            <!-- Phase progress -->
            <div style="margin-top:8px;">
              <div style="display:flex;justify-content:space-between;font-size:.84rem;color:var(--gray-600);margin-bottom:6px;">
                <span>Week 1 of 6</span>
                <span style="font-weight:700;">17% complete</span>
              </div>
              <div class="progress-bar" style="height:8px;"><div class="fill fill-blue" style="width:17%;"></div></div>
              <div style="display:flex;justify-content:space-between;margin-top:8px;font-size:.78rem;color:var(--gray-500);">
                <span>Started: Mar 20, 2026</span>
                <span>Ends: May 1, 2026</span>
              </div>
            </div>

            <!-- Exit Criteria -->
            <div style="margin-top:20px;padding-top:16px;border-top:1px solid rgba(14,165,233,.2);">
              <div style="font-weight:700;font-size:.9rem;color:var(--gray-800);margin-bottom:10px;">Definition of Done / Exit Criteria</div>
              <div style="display:flex;flex-direction:column;gap:8px;font-size:.84rem;">
                <div style="display:flex;align-items:center;gap:8px;color:var(--gray-600);">
                  <span style="color:var(--gray-300);">&#x25CB;</span> Reach 52.5 kg body weight
                </div>
                <div style="display:flex;align-items:center;gap:8px;color:var(--gray-600);">
                  <span style="color:var(--gray-300);">&#x25CB;</span> Waist below 66 cm
                </div>
                <div style="display:flex;align-items:center;gap:8px;color:var(--gray-600);">
                  <span style="color:var(--gray-300);">&#x25CB;</span> Maintain all compound lift numbers
                </div>
                <div style="display:flex;align-items:center;gap:8px;color:var(--gray-600);">
                  <span style="color:var(--warning);">&#x26A0;&#xFE0F;</span> Energy drops below 2/5 for 2+ weeks = end early
                </div>
              </div>
            </div>
          </div>

          <!-- Phase Stats -->
          <div class="grid-3 fade-in" style="animation-delay:.1s;margin-bottom:8px;">
            <div class="card card-sm" style="text-align:center;">
              <div class="text-xs text-muted" style="margin-bottom:2px;">Sessions Done</div>
              <div style="font-size:1.25rem;font-weight:800;">2</div>
              <div class="text-xs text-muted">of 18 total</div>
            </div>
            <div class="card card-sm" style="text-align:center;">
              <div class="text-xs text-muted" style="margin-bottom:2px;">Weight Change</div>
              <div style="font-size:1.25rem;font-weight:800;color:var(--success);">-0.4 kg</div>
              <div class="text-xs text-muted">54.1 &rarr; 53.7</div>
            </div>
            <div class="card card-sm" style="text-align:center;">
              <div class="text-xs text-muted" style="margin-bottom:2px;">Adherence</div>
              <div style="font-size:1.25rem;font-weight:800;">97%</div>
              <div class="text-xs text-muted">72/74 sets</div>
            </div>
          </div>

          <!-- Past Phases -->
          <div class="section-title mt-3" style="display:flex;justify-content:space-between;align-items:center;">
            <span>Past Phases</span>
            <button class="btn btn-sm btn-primary" onclick="showNewPhaseWizard()">+ New Phase</button>
          </div>

          <div class="phase-card-past fade-in" style="animation-delay:.15s;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
              <div>
                <div style="font-weight:700;font-size:1.02rem;color:var(--gray-800);">Volumen Dic-Feb</div>
                <div class="text-xs text-muted mt-1">Build &middot; 8 weeks &middot; Dec 2025 - Feb 2026</div>
              </div>
              <span class="badge badge-green">Completed</span>
            </div>
            <div class="grid-3" style="gap:12px;">
              <div style="text-align:center;background:var(--gray-50);border-radius:var(--radius-xs);padding:10px;">
                <div class="text-xs text-muted">Weight</div>
                <div style="font-weight:700;">+1.2 kg</div>
              </div>
              <div style="text-align:center;background:var(--gray-50);border-radius:var(--radius-xs);padding:10px;">
                <div class="text-xs text-muted">Top Lifts</div>
                <div style="font-weight:700;">All Up</div>
              </div>
              <div style="text-align:center;background:var(--gray-50);border-radius:var(--radius-xs);padding:10px;">
                <div class="text-xs text-muted">Adherence</div>
                <div style="font-weight:700;">92%</div>
              </div>
            </div>
          </div>

          <div class="phase-card-past fade-in" style="animation-delay:.2s;opacity:.85;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
              <div>
                <div style="font-weight:700;font-size:1.02rem;color:var(--gray-800);">Fuerza Oct-Nov</div>
                <div class="text-xs text-muted mt-1">Strength &middot; 6 weeks &middot; Oct - Nov 2025</div>
              </div>
              <span class="badge badge-green">Completed</span>
            </div>
            <div class="grid-3" style="gap:12px;">
              <div style="text-align:center;background:var(--gray-50);border-radius:var(--radius-xs);padding:10px;">
                <div class="text-xs text-muted">Weight</div>
                <div style="font-weight:700;">+0.8 kg</div>
              </div>
              <div style="text-align:center;background:var(--gray-50);border-radius:var(--radius-xs);padding:10px;">
                <div class="text-xs text-muted">Top Lifts</div>
                <div style="font-weight:700;">Most Up</div>
              </div>
              <div style="text-align:center;background:var(--gray-50);border-radius:var(--radius-xs);padding:10px;">
                <div class="text-xs text-muted">Adherence</div>
                <div style="font-weight:700;">88%</div>
              </div>
            </div>
          </div>
        </div>

        <!-- SESSION EDITOR (Hevy Coach style) -->
        <div id="sessionEditor" style="display:none;">
          <!-- Top bar: Back + Breadcrumb + Saved status -->
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--gray-100);">
            <button class="btn btn-ghost btn-sm" onclick="showPlanHome()" style="margin-left:-8px;padding:6px 12px;font-size:.9rem;color:var(--gray-500);">&#x2190; Back</button>
            <span style="color:var(--gray-300);font-size:.8rem;">/</span>
            <span style="color:var(--gray-500);font-size:.84rem;">Definición Q1</span>
            <span style="color:var(--gray-300);font-size:.8rem;">/</span>
            <span id="sessionBreadcrumb" style="color:var(--gray-700);font-weight:600;font-size:.84rem;">Dia 1: Fuerza</span>
            <span style="margin-left:auto;font-size:.77rem;color:var(--success);font-weight:500;">&#x2714; Saved</span>
          </div>

          <!-- Session switcher pills -->
          <div id="sessionPills" style="display:flex;gap:6px;margin-bottom:20px;">
            <button class="session-pill active" onclick="showSessionEditor('a')">Dia A: Fuerza</button>
            <button class="session-pill" onclick="showSessionEditor('b')">Dia B: Hipertrofia</button>
            <button class="session-pill" onclick="showSessionEditor('c')">Dia C: Volumen</button>
          </div>

          <!-- Editable Routine Title -->
          <div style="margin-bottom:8px;">
            <input id="sessionEditorTitle" type="text" value="Dia 1: Fuerza" style="font-size:1.4rem;font-weight:800;color:var(--gray-900);border:none;padding:8px 0;background:transparent;letter-spacing:-.02em;width:100%;" onfocus="this.style.borderBottom='2px solid var(--primary)'" onblur="this.style.borderBottom='none'">
          </div>

          <div id="sessionEditorMeta" style="display:flex;gap:8px;margin-bottom:18px;">
            <span class="badge badge-gray">Exercises: 7</span>
            <span class="badge badge-gray">Sets: 25</span>
            <span class="badge badge-gray">~75 min</span>
          </div>

          <!-- Routine Note -->
          <div style="margin-bottom:18px;">
            <div class="text-xs font-bold text-muted mb-1">Routine Note</div>
            <textarea id="sessionNote" class="exercise-block-note" style="height:50px;width:100%;" placeholder="Add a brief description of the routine">Fuerza: compound movements, heavy weights, low reps. Focus on progressive overload.</textarea>
          </div>

          <!-- Set Target RPE toggle -->
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:22px;">
            <div style="width:44px;height:24px;border-radius:12px;background:var(--primary);position:relative;cursor:pointer;">
              <div style="width:20px;height:20px;border-radius:50%;background:white;position:absolute;top:2px;right:2px;box-shadow:var(--shadow);"></div>
            </div>
            <span style="font-size:.87rem;font-weight:600;color:var(--gray-700);">Set Target RPE</span>
            <span style="font-size:.82rem;color:var(--gray-400);cursor:help;" title="Rate of Perceived Exertion - how hard each set should feel">&#x24D8;</span>
          </div>

          <!-- Exercise Blocks -->
          <div id="sessionExercises">
            <!-- Exercise 1: Hip Thrust -->
            <div class="exercise-block">
              <div class="exercise-block-header">
                <div class="exercise-block-icon">&#x1F3CB;&#xFE0F;</div>
