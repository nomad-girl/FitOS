            <div class="ex-lib-icon">&#x1F9B5;</div>
            <div class="ex-lib-info"><div class="ex-lib-name">Cable Kickback</div><div class="ex-lib-meta">Glutes</div></div>
          </div>
          <div class="ex-lib-item" data-name="Calf Raise" data-muscle="Calves" data-equip="Machine" onclick="showToast('Calf Raise added!')">
