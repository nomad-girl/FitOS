              <span>Started: Mar 20, 2026</span>
              <span>Ends: May 1, 2026</span>
            </div>
          </div>

          <!-- Exit Criteria / Definition of Done -->
          <div style="margin-top:20px;padding-top:16px;border-top:1px solid rgba(14,165,233,.2);">
            <div style="font-weight:700;font-size:.9rem;color:var(--gray-800);margin-bottom:10px;">Definition of Done / Exit Criteria</div>
            <div style="display:flex;flex-direction:column;gap:8px;font-size:.84rem;">
              <div style="display:flex;align-items:center;gap:8px;color:var(--gray-600);">
