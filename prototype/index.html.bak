                  <div class="exercise-block-name">Hip Thrust (Barbell) <span style="display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:10px;background:var(--success-light);color:#065F46;font-size:.68rem;font-weight:700;vertical-align:middle;">&#x1F4A1; Try 72.5kg</span></div>
                  <div class="exercise-block-muscle">Glutes &middot; Hinge &middot; <span style="color:var(--success);font-weight:600;">PR: 70kg x 6</span></div>
                </div>
                <span style="cursor:grab;color:var(--gray-300);font-size:.9rem;margin-right:2px;" title="Drag to reorder">&#x2630;</span><button class="exercise-block-menu">&#x22EE;</button>
              </div>
