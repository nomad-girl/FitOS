              </div>
              <div style="font-weight:800;font-size:1.3rem;color:var(--gray-900);margin-bottom:4px;">Definicion Q1</div>
              <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;">
                <span class="badge badge-yellow">Cut / Define</span>
                <span class="badge badge-gray">3x/week</span>
                <span class="badge badge-gray">Glutes, Back</span>
                <span class="badge badge-gray">1,650 kcal / 120g P</span>
              </div>
            </div>
