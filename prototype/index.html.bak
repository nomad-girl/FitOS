            <div class="ex-lib-icon">&#x1F3CB;&#xFE0F;</div>
            <div class="ex-lib-info"><div class="ex-lib-name">Arnold Press (Dumbbell)</div><div class="ex-lib-meta">Shoulders</div></div>
          </div>
          <div class="ex-lib-item" data-name="Back Extension" data-muscle="Back" data-equip="Bodyweight" onclick="showToast('Back Extension added!')">
            <span class="ex-lib-plus">+</span>
            <div class="ex-lib-icon">&#x1F9B5;</div>
            <div class="ex-lib-info"><div class="ex-lib-name">Back Extension</div><div class="ex-lib-meta">Back</div></div>
          </div>
          <div class="ex-lib-item" data-name="Barbell Row" data-muscle="Back" data-equip="Barbell" onclick="showToast('Barbell Row added!')">
            <span class="ex-lib-plus">+</span>
            <div class="ex-lib-icon">&#x1F4AA;</div>
            <div class="ex-lib-info"><div class="ex-lib-name">Barbell Row</div><div class="ex-lib-meta">Back</div></div>
          </div>
