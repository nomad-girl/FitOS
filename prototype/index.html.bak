<!-- MULTI-STEP PHASE WIZARD -->
<div class="wizard-overlay" id="newPhaseWizard" onclick="if(event.target===this)hideNewPhaseWizard();">
  <div class="wizard-panel" style="width:580px;padding:24px 28px;display:flex;flex-direction:column;">
    <!-- Header -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;flex-shrink:0;">
      <h2 style="font-size:1.1rem;font-weight:800;" id="phaseWizardTitle">New Phase</h2>
      <button onclick="hideNewPhaseWizard()" style="font-size:1.3rem;color:var(--gray-400);padding:4px;">&times;</button>
    </div>

    <!-- Step Indicators -->
    <div class="wizard-steps" id="wizardSteps">
      <div style="text-align:center;">
        <div class="wizard-step-dot active" data-step="1">1</div>
        <div class="wizard-step-label active">Basics</div>
      </div>
      <div class="wizard-step-line" data-line="1"></div>
      <div style="text-align:center;">
        <div class="wizard-step-dot" data-step="2">2</div>
        <div class="wizard-step-label">Volume</div>
      </div>
      <div class="wizard-step-line" data-line="2"></div>
      <div style="text-align:center;">
        <div class="wizard-step-dot" data-step="3">3</div>
        <div class="wizard-step-label">Nutrition</div>
      </div>
      <div class="wizard-step-line" data-line="3"></div>
      <div style="text-align:center;">
        <div class="wizard-step-dot" data-step="4">4</div>
        <div class="wizard-step-label">Exit</div>
      </div>
      <div class="wizard-step-line" data-line="4"></div>
      <div style="text-align:center;">
        <div class="wizard-step-dot" data-step="5">&#x2713;</div>
        <div class="wizard-step-label">Review</div>
      </div>
    </div>

    <!-- Scrollable step content area -->
    <div style="flex:1;overflow-y:auto;min-height:0;">

    <!-- STEP 1: Basics -->
    <div class="wizard-step-content active" id="wizStep1">
      <h3 style="font-size:.95rem;font-weight:700;margin-bottom:4px;">Phase Basics</h3>
      <p class="text-xs text-muted" style="margin-bottom:16px;">Define the foundation of your training phase.</p>

      <div class="mb-2">
        <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Phase Name</label>
        <input type="text" id="phaseWizardName" placeholder="e.g., Build Q2 2026">
      </div>

      <div class="grid-2 mb-2">
        <div>
          <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Goal</label>
          <select id="phaseWizardGoal">
            <option>Build / Volume</option>
            <option>Cut / Define</option>
            <option>Strength</option>
            <option>Maintenance</option>
          </select>
        </div>
        <div>
          <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Duration (weeks)</label>
          <select id="phaseWizardDuration">
            <option>4</option>
            <option>5</option>
            <option selected>6</option>
            <option>8</option>
            <option>10</option>
            <option>12</option>
          </select>
        </div>
      </div>

      <div class="grid-2 mb-2">
        <div>
          <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Training Days/Week</label>
          <select id="phaseWizardFreq">
            <option>2</option>
            <option selected>3</option>
            <option>4</option>
            <option>5</option>
            <option>6</option>
          </select>
        </div>
        <div>
          <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Split Type</label>
          <select id="phaseWizardSplit">
            <option>Full Body</option>
            <option selected>Upper / Lower</option>
            <option>Push / Pull / Legs</option>
            <option>Custom</option>
          </select>
        </div>
      </div>

      <div class="mb-2">
        <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Phase Objective (always visible on dashboard)</label>
        <input type="text" id="phaseWizardObjective" placeholder="e.g., Llegar a 52.5kg, cintura <66cm. Mantener fuerza.">
      </div>

      <div class="mb-2">
        <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Focus Muscles (priority)</label>
        <div class="chip-group" id="focusMuscleChips" style="display:flex;flex-wrap:wrap;gap:6px;">
          <span class="chip" onclick="toggleFocusChip(this)">Glutes</span>
          <span class="chip" onclick="toggleFocusChip(this)">Back</span>
          <span class="chip" onclick="toggleFocusChip(this)">Quads</span>
          <span class="chip" onclick="toggleFocusChip(this)">Hamstrings</span>
          <span class="chip" onclick="toggleFocusChip(this)">Chest</span>
          <span class="chip" onclick="toggleFocusChip(this)">Shoulders</span>
          <span class="chip" onclick="toggleFocusChip(this)">Arms</span>
          <span class="chip" onclick="toggleFocusChip(this)">Core</span>
          <span class="chip" onclick="toggleFocusChip(this)">Calves</span>
        </div>
      </div>

    </div>

    <!-- STEP 2: Focus & Volume -->
    <div class="wizard-step-content" id="wizStep2">
      <h3 style="font-size:.95rem;font-weight:700;margin-bottom:4px;">Volume Targets</h3>
      <p class="text-xs text-muted" style="margin-bottom:12px;">Set weekly sets per muscle group. Focus muscles are highlighted.</p>

      <div style="display:flex;gap:8px;margin-bottom:12px;">
        <button class="btn btn-sm btn-ghost" style="font-size:.78rem;" onclick="applyVolumePreset('beginner')">Beginner Preset</button>
        <button class="btn btn-sm btn-ghost" style="font-size:.78rem;" onclick="applyVolumePreset('intermediate')">Intermediate</button>
        <button class="btn btn-sm btn-ghost" style="font-size:.78rem;" onclick="applyVolumePreset('advanced')">Advanced</button>
      </div>

      <div style="display:flex;gap:4px;margin-bottom:8px;padding:0 0 6px;">
        <div class="vol-target-muscle" style="font-size:.7rem;color:var(--gray-400);font-weight:600;">MUSCLE</div>
        <div class="vol-target-inputs" style="gap:6px;">
          <div style="width:60px;text-align:center;font-size:.7rem;color:var(--gray-400);font-weight:600;">MEV</div>
          <div style="width:60px;text-align:center;font-size:.7rem;color:var(--gray-400);font-weight:600;">MAV</div>
          <div style="width:60px;text-align:center;font-size:.7rem;color:var(--gray-400);font-weight:600;">MRV</div>
        </div>
      </div>

      <div id="volumeTargetRows" style="max-height:280px;overflow-y:auto;">
        <!-- Populated by JS -->
      </div>

      <div class="alert-card" style="background:var(--primary-light);border:none;margin-top:12px;padding:10px 14px;">
        <span style="font-size:.8rem;color:var(--primary-dark);">&#x1F4A1; <strong>MEV</strong> = minimum effective volume &middot; <strong>MAV</strong> = maximum adaptive volume &middot; <strong>MRV</strong> = max recoverable volume</span>
      </div>

    </div>

    <!-- STEP 3: Nutrition -->
    <div class="wizard-step-content" id="wizStep3">
      <h3 style="font-size:.95rem;font-weight:700;margin-bottom:4px;">Nutrition & Activity</h3>
      <p class="text-xs text-muted" style="margin-bottom:16px;">Set your targets for this phase. You'll track weekly averages.</p>

      <div class="mb-2">
        <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Daily Calories Target</label>
        <input type="number" id="phaseWizardCal" placeholder="e.g., 1650">
      </div>

      <div style="margin-bottom:16px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
          <label class="text-xs text-muted">Macros</label>
          <div class="macro-toggle" id="macroToggle">
            <button class="active" onclick="switchMacroMode('grams', this)">Grams</button>
            <button onclick="switchMacroMode('pct', this)">Percent</button>
          </div>
        </div>

        <div class="grid-3" id="macroGramsInputs" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
          <div>
            <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Protein (g)</label>
            <input type="number" id="phaseWizardProt" placeholder="120" oninput="autoCalcMacros('grams')">
          </div>
          <div>
            <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Carbs (g)</label>
            <input type="number" id="phaseWizardCarbs" placeholder="165" oninput="autoCalcMacros('grams')">
          </div>
          <div>
            <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Fat (g)</label>
            <input type="number" id="phaseWizardFat" placeholder="55" oninput="autoCalcMacros('grams')">
          </div>
        </div>

        <div class="grid-3" id="macroPctInputs" style="display:none;grid-template-columns:1fr 1fr 1fr;gap:10px;">
          <div>
            <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Protein (%)</label>
            <input type="number" id="phaseWizardProtPct" placeholder="30" oninput="autoCalcMacros('pct')">
          </div>
          <div>
            <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Carbs (%)</label>
            <input type="number" id="phaseWizardCarbsPct" placeholder="40" oninput="autoCalcMacros('pct')">
          </div>
          <div>
            <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Fat (%)</label>
            <input type="number" id="phaseWizardFatPct" placeholder="30" oninput="autoCalcMacros('pct')">
          </div>
        </div>
        <div id="macroCalcHint" class="text-xs text-muted" style="margin-top:6px;"></div>
      </div>

      <div class="grid-2 mb-2">
        <div>
          <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Daily Steps Goal</label>
          <input type="number" id="phaseWizardSteps" placeholder="8000">
        </div>
        <div>
          <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Sleep Goal (hours)</label>
          <input type="number" id="phaseWizardSleep" placeholder="7.5" step="0.5">
        </div>
      </div>

    </div>

    <!-- STEP 4: Exit Criteria -->
    <div class="wizard-step-content" id="wizStep4">
      <h3 style="font-size:.95rem;font-weight:700;margin-bottom:4px;">Exit Criteria</h3>
      <p class="text-xs text-muted" style="margin-bottom:16px;">When should FitOS suggest ending this phase? Toggle the signals to monitor.</p>

      <div id="exitCriteriaList">
        <div class="exit-criteria-item">
          <div class="toggle-switch on" onclick="toggleSwitch(this)"></div>
          <div class="exit-criteria-desc">
            <div class="ec-title">Performance declining</div>
            <div class="ec-sub">Strength drops for 3+ consecutive weeks</div>
          </div>
        </div>
        <div class="exit-criteria-item">
          <div class="toggle-switch on" onclick="toggleSwitch(this)"></div>
          <div class="exit-criteria-desc">
            <div class="ec-title">Energy too low</div>
            <div class="ec-sub">Energy rating &#8804; 2/5 for 2+ weeks</div>
          </div>
        </div>
        <div class="exit-criteria-item">
          <div class="toggle-switch on" onclick="toggleSwitch(this)"></div>
          <div class="exit-criteria-desc">
            <div class="ec-title">Hunger too high</div>
            <div class="ec-sub">Hunger rating &#8805; 4/5 for 3+ weeks</div>
          </div>
        </div>
        <div class="exit-criteria-item">
          <div class="toggle-switch" onclick="toggleSwitch(this)"></div>
          <div class="exit-criteria-desc">
            <div class="ec-title">Weight stall</div>
            <div class="ec-sub">No weight change for 2+ weeks despite adherence</div>
          </div>
        </div>
        <div class="exit-criteria-item">
          <div class="toggle-switch" onclick="toggleSwitch(this)"></div>
          <div class="exit-criteria-desc">
            <div class="ec-title">Target reached</div>
            <div class="ec-sub">Goal weight or measurement achieved</div>
          </div>
        </div>
      </div>

      <div class="mb-2" style="margin-top:16px;">
        <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Custom exit note (optional)</label>
        <textarea id="phaseWizardExit" placeholder="e.g., End if waist goes below 66cm, or if I feel burnt out after week 4..." style="min-height:60px;"></textarea>
      </div>

    </div>

    <!-- STEP 5: Review -->
    <div class="wizard-step-content" id="wizStep5">
      <div id="wizardReviewContent">
        <!-- Populated by JS -->
      </div>
    </div>

    </div><!-- /scrollable step content -->

    <!-- SHARED FIXED FOOTER -->
    <div class="wizard-footer" id="wizardFooter" style="flex-shrink:0;padding-top:14px;border-top:1px solid var(--gray-100);margin-top:auto;">
      <button class="btn btn-ghost" id="wizFooterBack" onclick="wizardBack()">Cancel</button>
      <button class="btn btn-primary" id="wizFooterNext" onclick="wizardNext()">Next: Volume &#8594;</button>
    </div>

  </div>
</div>

<!-- END PHASE FLOW -->
<div class="wizard-overlay" id="endPhaseOverlay" onclick="if(event.target===this)hideEndPhaseFlow();">
  <div class="wizard-panel" style="max-width:420px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
      <h2 style="font-size:1.1rem;font-weight:800;">End Phase</h2>
      <button onclick="hideEndPhaseFlow()" style="font-size:1.3rem;color:var(--gray-400);padding:4px;">&times;</button>
    </div>

    <div class="alert-card alert-warning mb-2">
      &#x26A0;&#xFE0F; You're ending <strong>Definicion Q1</strong> at Week 1 of 6. This cannot be undone.
    </div>

    <div class="mb-2">
      <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Reason for ending</label>
      <div class="chip-group">
        <span class="chip" onclick="toggleChip(this)">Goals met</span>
        <span class="chip" onclick="toggleChip(this)">Plateau</span>
        <span class="chip" onclick="toggleChip(this)">Injury</span>
        <span class="chip" onclick="toggleChip(this)">Change of plans</span>
        <span class="chip" onclick="toggleChip(this)">Other</span>
      </div>
    </div>

    <div class="mb-2">
      <label class="text-xs text-muted" style="display:block;margin-bottom:4px;">Notes</label>
      <textarea placeholder="Optional notes about ending this phase..."></textarea>
    </div>

    <div style="display:flex;gap:10px;">
      <button class="btn btn-danger-outline" style="flex:1;" onclick="showToast('Phase ended. Start a new phase when ready.');hideEndPhaseFlow();">Confirm End Phase</button>
      <button class="btn btn-ghost" onclick="hideEndPhaseFlow()">Cancel</button>
    </div>
  </div>
</div>

<!-- STATS DRAWER (mobile) -->
<div class="stats-drawer-overlay" id="statsDrawer" onclick="if(event.target===this)closeStatsDrawer();">
  <div class="stats-drawer">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">
      <h3 style="font-weight:700;font-size:1rem;">Stats</h3>
      <button onclick="closeStatsDrawer()" style="font-size:1.3rem;color:var(--gray-400);">&times;</button>
    </div>

    <div class="grid-2" style="margin-bottom:16px;">
      <div class="card card-sm" style="text-align:center;margin-bottom:0;">
        <div class="text-xs text-muted">Exercises</div>
        <div style="font-size:1.2rem;font-weight:800;">21</div>
      </div>
      <div class="card card-sm" style="text-align:center;margin-bottom:0;">
        <div class="text-xs text-muted">Sets</div>
        <div style="font-size:1.2rem;font-weight:800;">74</div>
      </div>
    </div>

    <table class="muscle-table">
      <tr><td><span class="dot dot-red"></span></td><td class="m-name">Glutes</td><td class="m-count" style="color:var(--danger);font-weight:700;">8 / 14</td></tr>
      <tr><td><span class="dot dot-green"></span></td><td class="m-name">Back</td><td class="m-count">15 / 14</td></tr>
      <tr><td><span class="dot dot-green"></span></td><td class="m-name">Quads</td><td class="m-count">12 / 12</td></tr>
      <tr><td><span class="dot dot-green"></span></td><td class="m-name">Hamstrings</td><td class="m-count">10 / 10</td></tr>
      <tr><td><span class="dot dot-green"></span></td><td class="m-name">Chest</td><td class="m-count">9 / 8</td></tr>
      <tr><td><span class="dot dot-yellow"></span></td><td class="m-name">Shoulders</td><td class="m-count" style="color:var(--warning);">6 / 8</td></tr>
      <tr><td><span class="dot dot-green"></span></td><td class="m-name">Biceps</td><td class="m-count">6 / 6</td></tr>
      <tr><td><span class="dot dot-green"></span></td><td class="m-name">Triceps</td><td class="m-count">6 / 6</td></tr>
      <tr><td><span class="dot dot-yellow"></span></td><td class="m-name">Core</td><td class="m-count" style="color:var(--warning);">9 / 6</td></tr>
      <tr><td><span class="dot dot-yellow"></span></td><td class="m-name">Calves</td><td class="m-count" style="color:var(--warning);">2 / 4</td></tr>
    </table>

    <div class="alert-card alert-warning mt-2">Glutes: 6 sets below target</div>
  </div>
</div>

<!-- ============================================================
     JAVASCRIPT
     ============================================================ -->
<script>
/* ---- Tab / Screen switching ---- */
var wrappers = {
  dashboard: document.getElementById('dashboardWrapper'),
  plan: document.getElementById('planWrapper'),
  progress: document.getElementById('progressWrapper'),
  journal: document.getElementById('journalWrapper'),
  learn: document.getElementById('learnWrapper')
};
var panels = {
  dashboard: document.getElementById('dashboardPanel'),
  plan: document.getElementById('planPanel'),
  progress: document.getElementById('progressPanel'),
  journal: document.getElementById('journalPanel'),
  learn: document.getElementById('learnPanel')
};

var currentTab = 'dashboard';
var tabList = ['dashboard','plan','progress','journal','learn'];

function switchTab(tab) {
  currentTab = tab;

  // Hide all wrappers
  Object.values(wrappers).forEach(function(w) { if(w) w.style.display = 'none'; });

  // Hide all right panels
  Object.values(panels).forEach(function(p) { if(p) p.classList.remove('visible'); });

  // Show selected wrapper
  if (wrappers[tab]) wrappers[tab].style.display = '';

  // Show the matching right panel
  if (panels[tab]) panels[tab].classList.add('visible');

  // Update sidebar nav
  document.querySelectorAll('.nav-item').forEach(function(n, i) {
    n.classList.toggle('active', tabList[i] === tab);
  });
  // Update bottom tabs
  document.querySelectorAll('.btab').forEach(function(b, i) {
    b.classList.toggle('active', tabList[i] === tab);
  });

  // Reset sub-views when navigating away
  if (tab === 'plan') { showPlanHome(); switchPlanTab('routines'); }
  if (tab === 'progress') hideComparison();
}

/* ---- Plan sub-navigation ---- */
var sessionABlocksHTML = ''; // stored on first load

function showSessionEditor(session) {
  document.getElementById('planHome').style.display = 'none';
  document.getElementById('planPhaseView').style.display = 'none';
  document.getElementById('planSubTabs').style.display = 'none';
  document.getElementById('sessionEditor').style.display = '';
  showExerciseLibraryInPanel();

  // Update session pills
  var pillLabels = { a: 0, b: 1, c: 2 };
  document.querySelectorAll('.session-pill').forEach(function(p, i) {
    p.classList.toggle('active', i === pillLabels[session]);
  });

  var titles = { a: 'Dia 1: Fuerza', b: 'Dia B: Hipertrofia', c: 'Dia C: Volumen' };
  var notes = { a: 'Fuerza: compound movements, heavy weights, low reps. Focus on progressive overload.', b: 'Hipertrofia: moderate weight, higher reps. Focus on muscle tension and pump.', c: 'Volumen: isolation work, accessories. Fill volume gaps for focus muscles.' };
  var sets = { a: '25', b: '23', c: '26' };
  var exCounts = { a: '7', b: '7', c: '7' };
  var durations = { a: '~75 min', b: '~70 min', c: '~80 min' };

  document.getElementById('sessionEditorTitle').value = titles[session] || titles.a;
  document.getElementById('sessionBreadcrumb').textContent = titles[session] || titles.a;
  document.getElementById('sessionNote').value = notes[session] || notes.a;
  document.getElementById('sessionEditorMeta').innerHTML =
    '<span class="badge badge-gray">Exercises: ' + (exCounts[session]||7) + '</span>' +
    '<span class="badge badge-gray">Sets: ' + (sets[session]||25) + '</span>' +
    '<span class="badge badge-gray">' + (durations[session]||'~75 min') + '</span>';

  var exDiv = document.getElementById('sessionExercises');

  // Save session A's static HTML on first use
  if (!sessionABlocksHTML) {
    sessionABlocksHTML = exDiv.innerHTML;
  }

  if (session === 'a') {
    exDiv.innerHTML = sessionABlocksHTML;
  } else if (session === 'b') {
    exDiv.innerHTML = buildExerciseBlocks([
      {name:'Hip Thrust (Barbell)', muscle:'Glutes', pattern:'Hinge', icon:'&#x1F3CB;&#xFE0F;', rest:'01:30', sets:[{reps:'10-12',rpe:'7'},{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'8'}]},
      {name:'Negative Pull Up', muscle:'Back', pattern:'V. Pull', icon:'&#x1F4AA;', rest:'02:00', sets:[{reps:'4-6',rpe:'8'},{reps:'4-6',rpe:'9'},{reps:'4-6',rpe:'9'},{reps:'4-6',rpe:'9.5'}]},
      {name:'Reverse Lunge (Dumbbell)', muscle:'Quads, Glutes', pattern:'Lunge', icon:'&#x1F9CE;', rest:'01:30', sets:[{reps:'8-10',rpe:'8'},{reps:'8-10',rpe:'8'},{reps:'8-10',rpe:'9'}]},
      {name:'Seated Cable Row - V Grip', muscle:'Back', pattern:'H. Pull', icon:'&#x1F4AA;', rest:'01:30', sets:[{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'9'}]},
      {name:'Lying Leg Curl (Machine)', muscle:'Hamstrings', pattern:'Isolation', icon:'&#x1F9B5;', rest:'01:00', sets:[{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'9'},{reps:'10-12',rpe:'9'}]},
      {name:'Shoulder Press (Dumbbell)', muscle:'Shoulders', pattern:'V. Push', icon:'&#x1F3CB;&#xFE0F;', rest:'01:30', sets:[{reps:'8-10',rpe:'8'},{reps:'8-10',rpe:'9'},{reps:'8-10',rpe:'9'}]},
      {name:'Bicep Curl (Dumbbell)', muscle:'Biceps', pattern:'Isolation', icon:'&#x1F4AA;', rest:'01:00', sets:[{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'9'}]}
    ]);
  } else if (session === 'c') {
    exDiv.innerHTML = buildExerciseBlocks([
      {name:'Romanian Deadlift (Barbell)', muscle:'Hamstrings, Glutes', pattern:'Hinge', icon:'&#x1F9B5;', rest:'01:30', sets:[{reps:'8-10',rpe:'8'},{reps:'8-10',rpe:'8'},{reps:'8-10',rpe:'9'},{reps:'8-10',rpe:'9.5'}]},
      {name:'Single Arm Lateral Raise (Cable)', muscle:'Shoulders', pattern:'Isolation', icon:'&#x1F3CB;&#xFE0F;', rest:'01:00', sets:[{reps:'12-15',rpe:'7'},{reps:'12-15',rpe:'8'},{reps:'12-15',rpe:'8'},{reps:'12-15',rpe:'9'}]},
      {name:'Bicep Curl (Cable)', muscle:'Biceps', pattern:'Isolation', icon:'&#x1F4AA;', rest:'01:00', sets:[{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'9'}]},
      {name:'Hip Abduction (Machine)', muscle:'Glutes', pattern:'Isolation', icon:'&#x1F9B5;', rest:'01:00', sets:[{reps:'12-15',rpe:'8'},{reps:'12-15',rpe:'9'},{reps:'12-15',rpe:'9'}]},
      {name:'Plank', muscle:'Core', pattern:'Isometric', icon:'&#x1F9D8;', rest:'01:00', isDuration:true, sets:[{reps:'45s',rpe:'7'},{reps:'45s',rpe:'8'},{reps:'45s',rpe:'8'}]},
      {name:'Cable Kickback', muscle:'Glutes', pattern:'Isolation', icon:'&#x1F9B5;', rest:'01:00', sets:[{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'9'}]},
      {name:'Tricep Pushdown (Cable)', muscle:'Triceps', pattern:'Isolation', icon:'&#x1F4AA;', rest:'01:00', sets:[{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'8'},{reps:'10-12',rpe:'9'}]}
    ]);
  }
}

function buildExerciseBlocks(exercises) {
  return exercises.map(function(ex) {
    var restOptions = ['00:45','01:00','01:30','02:00','02:30','03:00'];
    var rpeOptions = ['6','6.5','7','7.5','8','8.5','9','9.5','10'];

    var setsHTML = ex.sets.map(function(s, i) {
      var repCell;
      if (ex.isDuration) {
        repCell = '<td><input class="set-input" value="' + s.reps + '" style="max-width:80px;"></td>';
      } else {
        var parts = s.reps.split('-');
        repCell = '<td><div class="rep-range-cell"><input class="set-input set-input-sm" value="' + parts[0] + '"><span>-</span><input class="set-input set-input-sm" value="' + (parts[1]||parts[0]) + '"></div></td>';
      }
      var rpeOpts = rpeOptions.map(function(r) { return '<option' + (r === s.rpe ? ' selected' : '') + '>' + r + '</option>'; }).join('');
      return '<tr>' +
        '<td><span class="set-number">' + (i+1) + '</span></td>' +
        '<td><input class="set-input" type="text" placeholder="--"></td>' +
        repCell +
        '<td><select class="rpe-select">' + rpeOpts + '</select></td>' +
        '<td><button class="set-delete">&times;</button></td>' +
      '</tr>';
    }).join('');

    var restOpts = restOptions.map(function(r) { return '<option' + (r === ex.rest ? ' selected' : '') + '>' + r + '</option>'; }).join('');
    var repHeader = ex.isDuration ? 'DURATION' : 'REP RANGE';

    return '<div class="exercise-block">' +
      '<div class="exercise-block-header">' +
        '<div class="exercise-block-icon">' + ex.icon + '</div>' +
        '<div class="exercise-block-title">' +
          '<div class="exercise-block-name">' + ex.name + '</div>' +
          '<div class="exercise-block-muscle">' + ex.muscle + ' &middot; ' + ex.pattern + '</div>' +
        '</div>' +
        '<span style="cursor:grab;color:var(--gray-300);font-size:.9rem;margin-right:2px;" title="Drag to reorder">&#x2630;</span><button class="exercise-block-menu">&#x22EE;</button>' +
      '</div>' +
      '<div class="exercise-block-body">' +
        '<textarea class="exercise-block-note" placeholder="Add pinned note"></textarea>' +
        '<div class="exercise-block-rest"><span>Rest Timer:</span><select>' + restOpts + '</select></div>' +
        '<table class="set-table">' +
          '<thead><tr><th>SET</th><th>KG</th><th>' + repHeader + '</th><th>TARGET RPE</th><th></th></tr></thead>' +
          '<tbody>' + setsHTML + '</tbody>' +
        '</table>' +
        '<button class="add-set-btn">+ Add set</button>' +
      '</div>' +
    '</div>';
  }).join('');
}

function showPlanHome() {
  document.getElementById('sessionEditor').style.display = 'none';
  document.getElementById('planSubTabs').style.display = '';
  // Show whichever plan sub-tab was active
  var isPhase = document.getElementById('planTabPhase').classList.contains('active');
  document.getElementById('planHome').style.display = isPhase ? 'none' : '';
  document.getElementById('planPhaseView').style.display = isPhase ? '' : 'none';
  hideExerciseLibraryInPanel();
}

function switchPlanTab(tab) {
  document.getElementById('planTabRoutines').classList.toggle('active', tab === 'routines');
  document.getElementById('planTabPhase').classList.toggle('active', tab === 'phase');
  document.getElementById('planHome').style.display = tab === 'routines' ? '' : 'none';
  document.getElementById('planPhaseView').style.display = tab === 'phase' ? '' : 'none';
  document.getElementById('sessionEditor').style.display = 'none';
  document.getElementById('planSubTabs').style.display = '';
  hideExerciseLibraryInPanel();
  // Update right panel based on sub-tab
  var summary = document.getElementById('planPanelSummary');
  var phasePanel = document.getElementById('planPanelPhaseInfo');
  if (summary) summary.style.display = tab === 'routines' ? '' : 'none';
  if (phasePanel) phasePanel.style.display = tab === 'phase' ? '' : 'none';
}

function showExerciseLibraryInPanel() {
  document.getElementById('planPanelSummary').style.display = 'none';
  document.getElementById('planPanelExercises').style.display = '';
}

function hideExerciseLibraryInPanel() {
  document.getElementById('planPanelSummary').style.display = '';
  document.getElementById('planPanelExercises').style.display = 'none';
}

function filterExLib() {
  var search = (document.getElementById('exLibSearch').value || '').toLowerCase();
  var equip = document.getElementById('exLibEquip').value;
  var muscle = document.getElementById('exLibMuscle').value;
  var items = document.querySelectorAll('.ex-lib-item');
  items.forEach(function(el) {
    var name = (el.getAttribute('data-name') || '').toLowerCase();
    var eqVal = el.getAttribute('data-equip') || '';
    var muVal = el.getAttribute('data-muscle') || '';
    var matchSearch = !search || name.indexOf(search) !== -1;
    var matchEquip = !equip || eqVal === equip;
    var matchMuscle = !muscle || muVal === muscle || (el.querySelector('.ex-lib-meta') && el.querySelector('.ex-lib-meta').textContent.indexOf(muscle) !== -1);
    el.style.display = (matchSearch && matchEquip && matchMuscle) ? '' : 'none';
  });
}

