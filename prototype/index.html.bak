            <div class="ex-lib-icon">&#x1F9D8;</div>
            <div class="ex-lib-info"><div class="ex-lib-name">Ab Scissors</div><div class="ex-lib-meta">Abdominals</div></div>
          </div>
          <div class="ex-lib-item" data-name="Arnold Press" data-muscle="Shoulders" data-equip="Dumbbell" onclick="showToast('Arnold Press added!')">
