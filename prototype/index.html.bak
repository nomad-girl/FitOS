function showComparison(session) {
  document.getElementById('progressHome').style.display = 'none';
  document.getElementById('comparisonView').style.display = '';

  var titles = { a: 'Day A: Fuerza', b: 'Day B: Hipertrofia', c: 'Day C: Volumen' };
  document.getElementById('comparisonTitle').textContent = titles[session];

  document.getElementById('comparisonWarning').style.display = session === 'b' ? '' : 'none';

  var body = document.getElementById('comparisonBody');
  var data = comparisonData[session] || comparisonData.a;
  body.innerHTML = data.map(function(row) {
    var cls = row[3].indexOf('\u2705') >= 0 ? 'text-success' : 'text-warning';
    return '<tr>' +
      '<td style="font-weight:600;">' + row[0] + '</td>' +
      '<td class="text-muted">' + row[1] + '</td>' +
      '<td>' + row[2] + '</td>' +
      '<td class="' + cls + '" style="font-weight:600;">' + row[3] + '</td>' +
    '</tr>';
  }).join('');
}

function hideComparison() {
  document.getElementById('progressHome').style.display = '';
  document.getElementById('comparisonView').style.display = 'none';
}

