/* ---- Login screen ---- */
function sendMagicLink() {
  var email = document.getElementById('loginEmail').value.trim();
  if (!email || email.indexOf('@') === -1) {
    document.getElementById('loginEmail').style.borderColor = 'var(--danger)';
    document.getElementById('loginEmail').focus();
    return;
  }
  document.getElementById('loginSentEmail').textContent = email;
  document.getElementById('loginForm').style.display = 'none';
  document.getElementById('loginInbox').style.display = 'block';
}
function resendMagicLink() {
  showToast('Magic link resent!');
}
function backToLoginForm() {
  document.getElementById('loginForm').style.display = '';
  document.getElementById('loginInbox').style.display = 'none';
}
function skipLogin() {
  var ls = document.getElementById('loginScreen');
  ls.classList.add('hidden');
  document.getElementById('appShell').style.display = '';
  setTimeout(function() { ls.style.display = 'none'; }, 500);
}
// Also allow Enter key on email input
document.getElementById('loginEmail').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') sendMagicLink();
});

/* ---- Phase management (multi-step wizard) ---- */
var wizardCurrentStep = 1;
var wizardMode = 'create'; // 'create' or 'edit'

var muscleVolumes = [
  { name: 'Glutes', mev: 6, mav: 14, mrv: 20, focus: false },
  { name: 'Back', mev: 8, mav: 14, mrv: 20, focus: false },
  { name: 'Quads', mev: 6, mav: 12, mrv: 18, focus: false },
  { name: 'Hamstrings', mev: 4, mav: 10, mrv: 16, focus: false },
  { name: 'Chest', mev: 6, mav: 10, mrv: 16, focus: false },
  { name: 'Shoulders', mev: 6, mav: 10, mrv: 16, focus: false },
  { name: 'Biceps', mev: 4, mav: 8, mrv: 14, focus: false },
  { name: 'Triceps', mev: 4, mav: 8, mrv: 14, focus: false },
  { name: 'Core', mev: 2, mav: 6, mrv: 12, focus: false },
  { name: 'Calves', mev: 4, mav: 8, mrv: 14, focus: false }
];

function buildVolumeRows() {
  var container = document.getElementById('volumeTargetRows');
  var focusChips = document.querySelectorAll('#focusMuscleChips .chip.selected');
  var focusMuscles = [];
  focusChips.forEach(function(c) { focusMuscles.push(c.textContent.trim()); });

  container.innerHTML = muscleVolumes.map(function(m) {
    var isFocus = focusMuscles.indexOf(m.name) !== -1 || (m.name === 'Arms' && (focusMuscles.indexOf('Biceps') !== -1 || focusMuscles.indexOf('Triceps') !== -1));
    var highlight = isFocus ? 'background:var(--primary-light);border-radius:var(--radius-xs);padding:8px 10px;' : 'padding:8px 0;';
    var badge = isFocus ? ' <span style="font-size:.65rem;background:var(--primary);color:#fff;padding:1px 6px;border-radius:8px;font-weight:600;">FOCUS</span>' : '';
    return '<div class="vol-target-row" style="' + highlight + '">' +
      '<div class="vol-target-muscle">' + m.name + badge + '</div>' +
      '<div class="vol-target-inputs">' +
        '<input type="number" value="' + m.mev + '" data-muscle="' + m.name + '" data-type="mev">' +
        '<input type="number" value="' + m.mav + '" data-muscle="' + m.name + '" data-type="mav">' +
        '<input type="number" value="' + m.mrv + '" data-muscle="' + m.name + '" data-type="mrv">' +
      '</div>' +
    '</div>';
  }).join('');
}

function applyVolumePreset(level) {
  var presets = {
    beginner: { mevMult: 1, mavMult: 0.7, mrvMult: 0.65 },
    intermediate: { mevMult: 1, mavMult: 1, mrvMult: 1 },
    advanced: { mevMult: 1.2, mavMult: 1.3, mrvMult: 1.2 }
  };
  var p = presets[level] || presets.intermediate;
  var base = [
    { name:'Glutes', mev:6, mav:14, mrv:20 }, { name:'Back', mev:8, mav:14, mrv:20 },
    { name:'Quads', mev:6, mav:12, mrv:18 }, { name:'Hamstrings', mev:4, mav:10, mrv:16 },
    { name:'Chest', mev:6, mav:10, mrv:16 }, { name:'Shoulders', mev:6, mav:10, mrv:16 },
    { name:'Biceps', mev:4, mav:8, mrv:14 }, { name:'Triceps', mev:4, mav:8, mrv:14 },
    { name:'Core', mev:2, mav:6, mrv:12 }, { name:'Calves', mev:4, mav:8, mrv:14 }
  ];
  muscleVolumes = base.map(function(m) {
    return { name: m.name, mev: Math.round(m.mev * p.mevMult), mav: Math.round(m.mav * p.mavMult), mrv: Math.round(m.mrv * p.mrvMult) };
  });
  buildVolumeRows();
  showToast(level.charAt(0).toUpperCase() + level.slice(1) + ' preset applied');
}

function toggleFocusChip(el) {
  el.classList.toggle('selected');
}

function switchMacroMode(mode, btn) {
  document.getElementById('macroToggle').querySelectorAll('button').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById('macroGramsInputs').style.display = mode === 'grams' ? 'grid' : 'none';
  document.getElementById('macroPctInputs').style.display = mode === 'pct' ? 'grid' : 'none';
}

function autoCalcMacros(from) {
  var cal = parseInt(document.getElementById('phaseWizardCal').value) || 0;
  if (!cal) { document.getElementById('macroCalcHint').textContent = ''; return; }

  if (from === 'grams') {
    var p = parseInt(document.getElementById('phaseWizardProt').value) || 0;
    var c = parseInt(document.getElementById('phaseWizardCarbs').value) || 0;
    var f = parseInt(document.getElementById('phaseWizardFat').value) || 0;
    var total = p * 4 + c * 4 + f * 9;
    document.getElementById('macroCalcHint').textContent = 'Total: ~' + total + ' kcal (' + (cal ? Math.round(p*4/cal*100) + '/' + Math.round(c*4/cal*100) + '/' + Math.round(f*9/cal*100) + '%' : '--') + ')';
  } else {
    var pp = parseInt(document.getElementById('phaseWizardProtPct').value) || 0;
    var cp = parseInt(document.getElementById('phaseWizardCarbsPct').value) || 0;
    var fp = parseInt(document.getElementById('phaseWizardFatPct').value) || 0;
    var sum = pp + cp + fp;
    var hint = sum !== 100 ? 'Total: ' + sum + '% (should be 100%)' : Math.round(pp/100*cal/4) + 'g P / ' + Math.round(cp/100*cal/4) + 'g C / ' + Math.round(fp/100*cal/9) + 'g F';
    document.getElementById('macroCalcHint').textContent = hint;
  }
}

function toggleSwitch(el) {
  el.classList.toggle('on');
}

var wizardStepLabels = ['', 'Volume', 'Nutrition', 'Exit Criteria', 'Review', ''];

function wizardGoTo(step) {
  wizardCurrentStep = step;

  // Rebuild volume rows when entering step 2
  if (step === 2) buildVolumeRows();

  // Build review when entering step 5
  if (step === 5) buildWizardReview();

  // Update step contents
  for (var i = 1; i <= 5; i++) {
    var el = document.getElementById('wizStep' + i);
    if (el) el.classList.toggle('active', i === step);
  }

  // Update dots & lines
  document.querySelectorAll('.wizard-step-dot').forEach(function(dot) {
    var s = parseInt(dot.getAttribute('data-step'));
    dot.classList.remove('active', 'done');
    if (s === step) dot.classList.add('active');
    else if (s < step) dot.classList.add('done');
  });
  document.querySelectorAll('.wizard-step-line').forEach(function(line) {
    var l = parseInt(line.getAttribute('data-line'));
    line.classList.toggle('done', l < step);
  });
  document.querySelectorAll('.wizard-step-label').forEach(function(lbl, i) {
    var s = i + 1;
    lbl.classList.remove('active', 'done');
    if (s === step) lbl.classList.add('active');
    else if (s < step) lbl.classList.add('done');
  });

  // Update shared footer buttons
  updateWizardFooter();

  // Scroll step area to top
  var scrollArea = document.querySelector('#newPhaseWizard .wizard-panel > div[style*="overflow-y"]');
  if (scrollArea) scrollArea.scrollTop = 0;
}

function updateWizardFooter() {
  var backBtn = document.getElementById('wizFooterBack');
  var nextBtn = document.getElementById('wizFooterNext');
  var step = wizardCurrentStep;

  if (step === 1) {
    backBtn.textContent = 'Cancel';
    backBtn.onclick = function() { hideNewPhaseWizard(); };
    nextBtn.textContent = 'Next: Volume \u2192';
    nextBtn.style.background = '';
    nextBtn.onclick = function() { wizardGoTo(2); };
  } else if (step === 2) {
    backBtn.innerHTML = '\u2190 Back';
    backBtn.onclick = function() { wizardGoTo(1); };
    nextBtn.textContent = 'Next: Nutrition \u2192';
    nextBtn.style.background = '';
    nextBtn.onclick = function() { wizardGoTo(3); };
  } else if (step === 3) {
    backBtn.innerHTML = '\u2190 Back';
    backBtn.onclick = function() { wizardGoTo(2); };
    nextBtn.textContent = 'Next: Exit Criteria \u2192';
    nextBtn.style.background = '';
    nextBtn.onclick = function() { wizardGoTo(4); };
  } else if (step === 4) {
    backBtn.innerHTML = '\u2190 Back';
    backBtn.onclick = function() { wizardGoTo(3); };
    nextBtn.textContent = 'Review \u2192';
    nextBtn.style.background = '';
    nextBtn.onclick = function() { wizardGoTo(5); };
  } else if (step === 5) {
    backBtn.innerHTML = '\u2190 Back';
    backBtn.onclick = function() { wizardGoTo(4); };
    nextBtn.innerHTML = '\u2713 ' + (wizardMode === 'edit' ? 'Save Phase' : 'Create Phase');
    nextBtn.style.background = 'var(--success)';
    nextBtn.onclick = function() {
      showToast(wizardMode === 'edit' ? 'Phase updated!' : 'Phase created!');
      hideNewPhaseWizard();
    };
  }
}

function wizardBack() {
  if (wizardCurrentStep === 1) hideNewPhaseWizard();
  else wizardGoTo(wizardCurrentStep - 1);
}

function wizardNext() {
  if (wizardCurrentStep === 5) {
    showToast(wizardMode === 'edit' ? 'Phase updated!' : 'Phase created!');
    hideNewPhaseWizard();
  } else {
    wizardGoTo(wizardCurrentStep + 1);
  }
}

function buildWizardReview() {
  var name = document.getElementById('phaseWizardName').value || 'Unnamed Phase';
  var objective = document.getElementById('phaseWizardObjective').value || '--';
  var goal = document.getElementById('phaseWizardGoal').value;
  var dur = document.getElementById('phaseWizardDuration').value;
  var freq = document.getElementById('phaseWizardFreq').value;
  var split = document.getElementById('phaseWizardSplit').value;
  var cal = document.getElementById('phaseWizardCal').value || '--';
  var prot = document.getElementById('phaseWizardProt').value || '--';
  var carbs = document.getElementById('phaseWizardCarbs').value || '--';
  var fat = document.getElementById('phaseWizardFat').value || '--';
  var steps = document.getElementById('phaseWizardSteps').value || '--';
  var sleep = document.getElementById('phaseWizardSleep').value || '--';

  var focusChips = document.querySelectorAll('#focusMuscleChips .chip.selected');
  var focus = [];
  focusChips.forEach(function(c) { focus.push(c.textContent.trim()); });

  var exitCriteria = [];
  document.querySelectorAll('#exitCriteriaList .exit-criteria-item').forEach(function(item) {
    var toggle = item.querySelector('.toggle-switch');
    if (toggle && toggle.classList.contains('on')) {
      exitCriteria.push(item.querySelector('.ec-title').textContent);
    }
  });

  var customExit = document.getElementById('phaseWizardExit').value;

  var html = '<div class="review-section">' +
    '<h4>Basics</h4>' +
    '<div class="review-grid">' +
      '<div class="review-item"><span class="ri-label">Name</span><span class="ri-value">' + name + '</span></div>' +
      '<div class="review-item" style="grid-column:1/-1;"><span class="ri-label">Objective</span><span class="ri-value" style="font-style:italic;">' + objective + '</span></div>' +
      '<div class="review-item"><span class="ri-label">Goal</span><span class="ri-value">' + goal + '</span></div>' +
      '<div class="review-item"><span class="ri-label">Duration</span><span class="ri-value">' + dur + ' weeks</span></div>' +
      '<div class="review-item"><span class="ri-label">Frequency</span><span class="ri-value">' + freq + 'x/week</span></div>' +
      '<div class="review-item"><span class="ri-label">Split</span><span class="ri-value">' + split + '</span></div>' +
      '<div class="review-item"><span class="ri-label">Focus</span><span class="ri-value">' + (focus.length ? focus.join(', ') : 'None') + '</span></div>' +
    '</div></div>';

  html += '<div class="review-section">' +
    '<h4>Nutrition</h4>' +
    '<div class="review-grid">' +
      '<div class="review-item"><span class="ri-label">Calories</span><span class="ri-value">' + cal + ' kcal</span></div>' +
      '<div class="review-item"><span class="ri-label">Protein</span><span class="ri-value">' + prot + 'g</span></div>' +
      '<div class="review-item"><span class="ri-label">Carbs</span><span class="ri-value">' + carbs + 'g</span></div>' +
      '<div class="review-item"><span class="ri-label">Fat</span><span class="ri-value">' + fat + 'g</span></div>' +
      '<div class="review-item"><span class="ri-label">Steps</span><span class="ri-value">' + steps + '/day</span></div>' +
      '<div class="review-item"><span class="ri-label">Sleep</span><span class="ri-value">' + sleep + ' hrs</span></div>' +
    '</div></div>';

  html += '<div class="review-section">' +
    '<h4>Exit Criteria</h4>' +
    '<div style="display:flex;flex-wrap:wrap;gap:6px;">';
  exitCriteria.forEach(function(ec) {
    html += '<span class="badge badge-blue" style="font-size:.78rem;">' + ec + '</span>';
  });
  if (!exitCriteria.length) html += '<span class="text-xs text-muted">No automatic exit criteria set</span>';
  html += '</div>';
  if (customExit) {
    html += '<div style="margin-top:8px;padding:8px 12px;background:var(--gray-50);border-radius:var(--radius-xs);font-size:.85rem;color:var(--gray-600);">' + customExit + '</div>';
  }
  html += '</div>';

  document.getElementById('wizardReviewContent').innerHTML = html;
}

function showNewPhaseWizard() {
  wizardMode = 'create';
  wizardCurrentStep = 1;
  document.getElementById('phaseWizardTitle').textContent = 'New Phase';
  // Reset all fields
  document.getElementById('phaseWizardName').value = '';
  document.getElementById('phaseWizardObjective').value = '';
  document.getElementById('phaseWizardGoal').value = 'Build / Volume';
  document.getElementById('phaseWizardDuration').value = '6';
  document.getElementById('phaseWizardFreq').value = '3';
  document.getElementById('phaseWizardSplit').value = 'Upper / Lower';
  document.getElementById('phaseWizardCal').value = '';
  document.getElementById('phaseWizardProt').value = '';
  document.getElementById('phaseWizardCarbs').value = '';
  document.getElementById('phaseWizardFat').value = '';
  document.getElementById('phaseWizardSteps').value = '';
  document.getElementById('phaseWizardSleep').value = '';
  document.getElementById('phaseWizardExit').value = '';
  document.getElementById('macroCalcHint').textContent = '';
  // Reset focus chips
  document.querySelectorAll('#focusMuscleChips .chip').forEach(function(c) { c.classList.remove('selected'); });
  // Reset exit toggles to defaults
  var toggles = document.querySelectorAll('#exitCriteriaList .toggle-switch');
  toggles.forEach(function(t, i) { t.classList.toggle('on', i < 3); });
  // Go to step 1
  wizardGoTo(1);
  document.getElementById('newPhaseWizard').classList.add('open');
}

function showEditPhaseWizard() {
  wizardMode = 'edit';
  wizardCurrentStep = 1;
  document.getElementById('phaseWizardTitle').textContent = 'Edit Phase';
  // Fill with existing data
  document.getElementById('phaseWizardName').value = 'Definicion Q1';
  document.getElementById('phaseWizardObjective').value = 'Llegar a 52.5kg, cintura <66cm. Mantener fuerza en compuestos.';
  document.getElementById('phaseWizardGoal').value = 'Cut / Define';
  document.getElementById('phaseWizardDuration').value = '6';
  document.getElementById('phaseWizardFreq').value = '3';
  document.getElementById('phaseWizardSplit').value = 'Upper / Lower';
  document.getElementById('phaseWizardCal').value = '1650';
  document.getElementById('phaseWizardProt').value = '120';
  document.getElementById('phaseWizardCarbs').value = '165';
  document.getElementById('phaseWizardFat').value = '55';
  document.getElementById('phaseWizardSteps').value = '8000';
  document.getElementById('phaseWizardSleep').value = '7.5';
  document.getElementById('phaseWizardExit').value = 'Reach 52.5kg, waist below 66cm.';
  // Select focus chips
  document.querySelectorAll('#focusMuscleChips .chip').forEach(function(c) {
    c.classList.toggle('selected', c.textContent === 'Glutes' || c.textContent === 'Back');
  });
  // Go to step 1
  wizardGoTo(1);
  document.getElementById('newPhaseWizard').classList.add('open');
}

function hideNewPhaseWizard() {
  document.getElementById('newPhaseWizard').classList.remove('open');
}
function showEndPhaseFlow() {
  document.getElementById('endPhaseOverlay').classList.add('open');
}
function hideEndPhaseFlow() {
  document.getElementById('endPhaseOverlay').classList.remove('open');
}

/* ---- Stats panel tabs ---- */
function switchStatsTab(el, tab) {
  el.parentNode.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
  el.classList.add('active');
  document.getElementById('statsMuscles').style.display = tab === 'muscles' ? '' : 'none';
  document.getElementById('statsPatterns').style.display = tab === 'patterns' ? '' : 'none';
}

/* ---- Mobile stats drawer ---- */
function openStatsDrawer() {
  document.getElementById('statsDrawer').classList.add('open');
}
function closeStatsDrawer() {
  document.getElementById('statsDrawer').classList.remove('open');
}

/* ---- Rating buttons ---- */
function setRating(el) {
  el.parentNode.querySelectorAll('.rating-btn').forEach(function(b) { b.classList.remove('selected'); });
  el.classList.add('selected');
}

/* ---- Chip toggles ---- */
function toggleChip(el) {
  var group = el.parentNode;
  if (group.classList.contains('chip-group')) {
    group.querySelectorAll('.chip').forEach(function(c) { c.classList.remove('selected'); });
  }
  el.classList.add('selected');
}

/* ---- Toast ---- */
function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(function() { t.classList.remove('show'); }, 2200);
}

/* ---- Simulate sync ---- */
function simulateSync() {
  showToast('Syncing with Hevy...');
  setTimeout(function() { showToast('Sync complete! All sessions up to date.'); }, 1500);
}

/* ---- Quick Log FAB ---- */
function openQuickLog() {
  document.getElementById('quickLogOverlay').classList.add('open');
  document.getElementById('fab').style.display = 'none';
}
function closeQuickLog() {
  document.getElementById('quickLogOverlay').classList.remove('open');
  document.getElementById('fab').style.display = '';
}

/* ---- Keyboard shortcuts (1-6 for tabs) ---- */
document.addEventListener('keydown', function(e) {
  if (e.key >= '1' && e.key <= '5' && !e.target.matches('input,textarea,select')) {
    switchTab(tabList[parseInt(e.key) - 1]);
  }
});

/* ---- Initialize: show dashboard with its panel ---- */
switchTab('dashboard');
</script>

</body>
</html>
