              <button class="btn btn-sm btn-outline" onclick="showEditPhaseWizard()">&#x270F;&#xFE0F; Edit</button>
              <button class="btn btn-sm btn-danger-outline" onclick="showEndPhaseFlow()">End Phase</button>
            </div>
          </div>

          <!-- Phase progress -->
