                <div class="exercise-block-rest">
                  <span>Rest Timer:</span>
                  <select>
                    <option>01:30</option>
                    <option selected>02:00</option>
                    <option>02:30</option>
                    <option>03:00</option>
                  </select>
                </div>
                <table class="set-table">
